#!/bin/bash
#
# This script automates the initial setup of a new Ubuntu-based work VM.
# It installs essential development tools, configures editors, and sets up
# system-level dependencies to get the environment ready for development.
#
# The script is designed to be run via chezmoi, which handles templating
# and ensures it's executed on the correct operating system.
#

touch ~/.env.sh

# Function to ensure the system time is synchronized using NTP.
# This is crucial for correct timestamps in logs, certificates, and various
# system operations, especially after a VM suspension.
function sync_time {
    echo "Ensuring system time is synchronized with NTP..."
    sudo timedatectl set-ntp true
    if [ $? -eq 0 ]; then
        echo "System time synchronization enabled."
    else
        echo "Failed to enable system time synchronization. Please check manually."
    fi
}

# Function to set up Spacemacs (Emacs distribution).
# This function first backs up any existing .emacs.d directory and then clones
# the Spacemacs repository to ensure a consistent Emacs setup.
function setup_emacs {
    mv $HOME/.emacs.d $HOME/.emacs.d`date -I`
    git clone https://github.com/syl20bnr/spacemacs $HOME/.emacs.d
}

# Function to set up LazyVim (Neovim configuration framework).
# This function ensures a clean installation of LazyVim by backing up
# existing Neovim configuration directories before cloning the starter template.
function setup_lazyvim {
    # required
    mv ~/.config/nvim{,.bak}

    # optional but recommended
    mv ~/.local/share/nvim{,.bak}
    mv ~/.local/state/nvim{,.bak}
    mv ~/.cache/nvim{,.bak}

    git clone https://github.com/LazyVim/starter ~/.config/nvim
    rm -rf ~/.config/nvim/.git
}

function setup_system_tools {
    # Installs core system development tools and libraries required for compiling
    # software, database clients, and various utilities. This ensures the VM
    # has a robust base for general development tasks.
    sudo apt-get update
    sudo apt-get install \
         build-essential pkg-config autoconf bison clang \
         libssl-dev libreadline-dev zlib1g-dev libyaml-dev libreadline-dev libncurses5-dev libffi-dev libgdbm-dev libjemalloc2 \
         libvips imagemagick libmagickwand-dev mupdf mupdf-tools gir1.2-gtop-2.0 gir1.2-clutter-1.0 \
         redis-tools sqlite3 libsqlite3-0 libmysqlclient-dev libpq-dev postgresql-client postgresql-client-common
    sudo apt-get install \
         neovim \
         git emacs \
         direnv btop \
         fzf ripgrep bat eza zoxide plocate apache2-utils fd-find tldr \
         kitty xclip \
         strace gdu \
         iputils-ping iproute2 dnsutils traceroute curl \
         mpv yt-dlp \
         i3 i3status
}

function setup_dev_tools {
    # Configures development tools using `mise` (formerly `rtx` or `asdf`).
    # This ensures specific versions of language runtimes and tools are available
    # globally, maintaining consistency across projects.
    mise use --global fd
    mise use --global bun
    mise use --global hurl
    mise use --global node@22
    mise use --global babashka@latest
    mise reshim
    npm install -g @github/copilot
    npm install -g vmd
}

function install_docker {
    # Installs Docker Engine and related components, providing containerization
    # capabilities essential for modern development workflows. It also configures
    # user permissions and log rotation to manage disk space.
    if command -v docker &> /dev/null; then
        echo "docker is already installed. Skipping installation."
        return
    fi
    # Add the official Docker repo
    sudo install -m 0755 -d /etc/apt/keyrings
    sudo wget -qO /etc/apt/keyrings/docker.asc https://download.docker.com/linux/ubuntu/gpg
    sudo chmod a+r /etc/apt/keyrings/docker.asc
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
    sudo apt update

    # Install Docker engine and standard plugins
    sudo apt install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin docker-ce-rootless-extras

    # Give this user privileged Docker access
    sudo usermod -aG docker ${USER}

    # Limit log size to avoid running out of disk
    echo '{"log-driver":"json-file","log-opts":{"max-size":"10m","max-file":"5"}}' | sudo tee /etc/docker/daemon.json
}

function set_font {
	# Helper function to download, install, and set a specific font.
	# This is used to ensure consistent font rendering across the system,
	# which is crucial for terminal and editor aesthetics.
	local font_name=$1
	local url=$2
	local file_type=$3
	local file_name="${font_name/ Nerd Font/}"

	if ! $(fc-list | grep -i "$font_name" >/dev/null); then
		cd /tmp
		wget -O "$file_name.zip" "$url"
		unzip "$file_name.zip" -d "$file_name"
		cp "$file_name"/*."$file_type" ~/.local/share/fonts
		rm -rf "$file_name.zip" "$file_name"
		fc-cache
		cd -
		clear
	fi

	gsettings set org.gnome.desktop.interface monospace-font-name "$font_name 10"
}

function install_desktop_fonts {
    # Installs a set of commonly used desktop fonts, including Nerd Fonts and iA Fonts.
    # These fonts are preferred for coding and general desktop use due to their legibility
    # and inclusion of programming ligatures/icons.
    mkdir -p ~/.local/share/fonts

    # install only if missing iAWriterMonoS-Bold.ttf
    if fc-list | grep -i "iAWriterMonoS-Bold" >/dev/null; then
        echo "iAWriterMonoS-Bold font already installed. Skipping font installation."
        return
    fi

    cd /tmp
    wget https://github.com/ryanoasis/nerd-fonts/releases/latest/download/CascadiaMono.zip
    unzip CascadiaMono.zip -d CascadiaFont
    cp CascadiaFont/*.ttf ~/.local/share/fonts
    rm -rf CascadiaMono.zip CascadiaFont

    wget -O iafonts.zip https://github.com/iaolo/iA-Fonts/archive/refs/heads/master.zip
    unzip iafonts.zip -d iaFonts
    cp iaFonts/iA-Fonts-master/iA\ Writer\ Mono/Static/iAWriterMonoS-*.ttf ~/.local/share/fonts
    rm -rf iafonts.zip iaFonts

    fc-cache
    cd -
}

function install_localsend {
    # Installs LocalSend, a cross-platform application for local file sharing.
    # This is included for convenient and secure file transfers within the local network.
    if command -v localsend &> /dev/null; then
        echo "localsend is already installed. Skipping installation."
        return
    fi

    echo "Installing localsend..."
    cd /tmp
    LOCALSEND_VERSION=$(curl -s "https://api.github.com/repos/localsend/localsend/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
    wget -O localsend.deb "https://github.com/localsend/localsend/releases/latest/download/LocalSend-${LOCALSEND_VERSION}-linux-x86-64.deb"
    sudo apt install -y ./localsend.deb
    rm localsend.deb
    cd -
}

function install_httpjail {
    if command -v httpjail &> /dev/null; then
        echo "httpjail is already installed. Skipping installation."
        return
    fi

    echo "Installing httpjail..."
    cargo install httpjail
}

{{- if eq .chezmoi.os "linux" }}

# Main execution block: These commands are run when the script is executed on a Linux system.
# The order of execution is important to ensure dependencies are met and configurations
# are applied correctly.

# Ensure system time is synchronized.
sync_time

# Increase the number of inotify watchers to prevent ENOSPC errors.
echo fs.inotify.max_user_watches=524288 | sudo tee /etc/sysctl.d/99-inotify.conf > /dev/null
sudo sysctl -p /etc/sysctl.d/99-inotify.conf

# Install httpjail
install_httpjail

# Set up Emacs if it's not already present.
if [ ! -d "$HOME/.emacs.d" ]; then
    setup_emacs
fi

# Set up LazyVim if it's not already present.
if [ ! -d "$HOME/.config/nvim" ]; then
    setup_lazyvim
fi

# Install essential system-wide development tools and libraries.
setup_system_tools

# Configure development tools using mise.
setup_dev_tools

# Install and configure Docker for containerization.
install_docker

# Install LocalSend for local file sharing (currently commented out).
# install_localsend

# Set the primary monospace font for the desktop environment.
set_font "CaskaydiaMono Nerd Font" "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/CascadiaMono.zip" "ttf"

# Install additional desktop fonts.
install_desktop_fonts

# Other font installations (currently commented out, can be enabled as needed).
# set_font "FiraMono Nerd Font" "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraMono.zip" "otf"
# set_font "JetBrainsMono Nerd Font" "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip" "ttf"
# set_font "MesloLGS Nerd Font" "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/Meslo.zip" "ttf"

{{- end}}
