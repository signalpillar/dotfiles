#!/usr/bin/env python3
"""Deterministic task harness prototype for pi-agent jobs.

The CUE task file remains the source of truth. This script reads task state via
`cue export`, loads the package-local `profile-contract.cue` for profiles and
phase ownership, computes the next actionable slice/step, can update the saved
orchestration cursor, and emits deterministic execution instructions for the
orchestrating model.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
from dataclasses import dataclass
from functools import lru_cache
from pathlib import Path
from typing import Any, Protocol
from uuid import uuid4

ROOT = Path.cwd()
PACKAGE_DIR = Path(__file__).resolve().parent.parent
PROFILE_CONTRACT = PACKAGE_DIR / "profile-contract.cue"
TASK_SCHEMA = PACKAGE_DIR / "task-schema.cue"
STATUS_DONE = {"done", "skipped"}
GLYPH = {"done": "✓", "skipped": "⊘", "in_progress": "▸", "blocked": "✗", "planned": "○"}


def die(message: str) -> None:
    print(f"error: {message}", file=sys.stderr)
    sys.exit(1)


def missing_task_hint(task_file: Path) -> str:
    return (
        f"task file not found: {task_file}\n"
        f"create one from the example shape with:\n"
        f"  pi-job --task {task_file} scaffold\n"
        f"then initialize a profile:\n"
        f"  pi-job --task {task_file} init --profile <profile>"
    )


def example_task_cue(*, title: str = "Example bounded change") -> str:
    """Generic task-file scaffold. Types/structure only; no real work content."""
    safe_title = title.replace('\\', '\\\\').replace('"', '\\"')
    return f'''package task

task: {{
	title:  "{safe_title}"
	status: "in_progress"

	source: {{
		jira:       ""
		discovered: ""
		context:    "Short discovery note for why this task exists."
	}}

	project: {{
		key:     "example"
		name:    "Example Project"
		route:   "projects/example/workflow.md"
		context: "Where this work lives in the repo."
	}}

	context: """
		Free-form background the agent should read before acting.
		Replace project/source fields, then add plan slices for the real work.
		"""

	decisions: []

	plan: {{
		note: "Replace this scaffold plan with the real slices for the work."
		slices: [
			#Slice & {{
				key:    "do-the-change"
				title:  "Do the change"
				goal:   "Ship the bounded edit with verification."
				status: "in_progress"
				note:   ""
				steps: [
					#Step & {{key: "edit-code", title: "Edit the code", status: "planned", note: ""}},
					#Step & {{key: "verify", title: "Run checks", status: "planned", note: ""}},
				]
				final_steps: [
					#Step & {{key: "e2e-evidence", title: "Provide e2e/acceptance evidence or record the gap", status: "planned", note: ""}},
					#Step & {{key: "reconcile-artifacts", title: "Reconcile toolbelt aids with what shipped — update or confirm no drift", status: "planned", note: ""}},
					#Step & {{key: "share-with-team", title: "Share with team: ticket + PR for this slice's repo", status: "planned", note: ""}},
					#Step & {{key: "update-task-file", title: "Update this task file plan", status: "planned", note: ""}},
				]
			}},
		]
	}}
}}
'''


@dataclass(frozen=True)
class Cursor:
    phase: str
    slice: str | None = None
    step: str | None = None

    def label(self) -> str:
        parts = [self.phase]
        if self.slice:
            parts.append(self.slice)
        if self.step:
            parts.append(self.step)
        return " / ".join(parts)


class TaskStore(Protocol):
    """Protocol for task storage backends. Currently only CueTaskStore exists."""

    def describe(self) -> str:
        """Return a human-readable description of the store (e.g., file path)."""
        ...

    def read(self) -> dict[str, Any]:
        """Read and export the task as a dict."""
        ...

    def set_cursor(self, cursor: Cursor) -> None:
        """Update the saved cursor position."""
        ...

    def set_profile(self, profile: str, cursor: Cursor) -> None:
        """Initialize orchestration with a profile and cursor."""
        ...

    def add_slice(
        self,
        *,
        key: str,
        title: str,
        goal: str,
        extra_fields: dict[str, list[str]],
        final_steps: list[tuple[str, str]],
        after: str | None,
    ) -> None:
        """Add a new slice to the task plan. extra_fields maps a non-baseline
        #Slice field name to its plain string values - backend-neutral, no
        pre-rendered CUE (or other backend-specific) syntax."""
        ...

    def add_step(
        self,
        *,
        slice_key: str,
        key: str,
        title: str,
        note: str,
        terminal: bool,
        after: str | None,
    ) -> None:
        """Add a new step to a slice (terminal=True for final_steps, False for steps)."""
        ...

    def set_worktree(self, *, slice_key: str, repo: str, path: str) -> None:
        """Set the worktree path for a slice's repo work."""
        ...

    def add_pr(
        self, *, slice_key: str, repo: str, url: str, status: str, note: str
    ) -> str:
        """Add or update a PR for a slice's repo work. Returns 'added' or 'updated'."""
        ...

    def write_artifact(
        self, key: str, *, status: str, path: str | None, note: str
    ) -> None:
        """Record a toolbelt artifact."""
        ...


class CueTaskStore:
    """Concrete TaskStore implementation using CUE files."""

    def __init__(self, path: Path) -> None:
        self.path = path

    def describe(self) -> str:
        return f"cue task file {self.path}"

    def read(self) -> dict[str, Any]:
        return load_task(self.path)

    def set_cursor(self, cursor: Cursor) -> None:
        text = self.path.read_text()
        pattern = re.compile(r"(?m)^[ \t]*cursor:\s*\{\n(?:[ \t]+.*\n)+?[ \t]*\}")
        new_text, count = pattern.subn(cursor_block(cursor), text, count=1)
        if count != 1:
            die("could not find exactly one orchestration cursor block to replace")
        write_and_format(self.path, new_text)

    def set_profile(self, profile: str, cursor: Cursor) -> None:
        get_profile(profile)

        text = self.path.read_text()
        block = orchestration_block(profile, cursor)
        if re.search(r"(?m)^[ \t]*orchestration:\s*\{", text):
            profile_pattern = re.compile(r'(?m)^([ \t]*profile:\s*)"[^"]*"')
            new_text, count = profile_pattern.subn(rf'\1"{profile}"', text, count=1)
            if count != 1:
                die("found orchestration block but could not replace profile")
            cursor_pattern = re.compile(r"(?m)^[ \t]*cursor:\s*\{\n(?:[ \t]+.*\n)+?[ \t]*\}")
            new_text, cursor_count = cursor_pattern.subn(cursor_block(cursor), new_text, count=1)
            if cursor_count != 1:
                die("found orchestration block but could not replace cursor")
        else:
            plan_match = re.search(r"(?m)^\tplan:\s*\{|^[ ]+plan:\s*\{", text)
            if not plan_match:
                die("could not find task.plan block to insert orchestration before")
            new_text = text[: plan_match.start()] + block + "\n\n" + text[plan_match.start() :]
        write_and_format(self.path, new_text)

    def add_slice(
        self,
        *,
        key: str,
        title: str,
        goal: str,
        extra_fields: dict[str, list[str]],
        final_steps: list[tuple[str, str]],
        after: str | None,
    ) -> None:
        literal = slice_literal(
            key=key, title=title, goal=goal, extra_fields=extra_fields, final_steps=final_steps
        )

        original_text = self.path.read_text()
        lines = original_text.splitlines(keepends=True)
        plan_idx = find_line(lines, re.compile(r"^[ \t]*plan:\s*\{\s*$"))
        if plan_idx == -1:
            die("could not find task.plan block")
        plan_close = find_block_close(lines, plan_idx)
        slices_open, slices_close, is_empty = find_array_span(lines, "slices", plan_idx, plan_close)

        new_lines = literal.splitlines(keepends=True)
        if after:
            span = find_key_struct_span(lines, after, slices_open, slices_close)
            if span is None:
                die(f"--after slice {after!r} not found in slices array text (unexpected)")
            lines = insert_lines(lines, span[1], new_lines, after=True)
        elif is_empty:
            lines = lines[:slices_open] + ["slices: [\n", *new_lines, "]\n"] + lines[slices_open + 1:]
        else:
            lines = insert_lines(lines, slices_close, new_lines, after=False)

        write_and_validate(self.path, original_text, "".join(lines))

    def add_step(
        self,
        *,
        slice_key: str,
        key: str,
        title: str,
        note: str,
        terminal: bool,
        after: str | None,
    ) -> None:
        literal = step_literal(key, title, note=note)
        group = "final_steps" if terminal else "steps"

        original_text = self.path.read_text()
        lines = original_text.splitlines(keepends=True)
        slice_span = find_key_struct_span(lines, slice_key)
        if slice_span is None:
            die(f"could not locate slice {slice_key!r} in task file text (unexpected)")
        arr_open, arr_close, is_empty = find_array_span(lines, group, slice_span[0], slice_span[1])

        new_lines = literal.splitlines(keepends=True)
        if after:
            span = find_key_struct_span(lines, after, arr_open, arr_close)
            if span is None:
                die(f"--after step {after!r} not found in {group} text (unexpected)")
            lines = insert_lines(lines, span[1], new_lines, after=True)
        elif is_empty:
            lines = lines[:arr_open] + [f"{group}: [\n", *new_lines, "]\n"] + lines[arr_open + 1:]
        else:
            lines = insert_lines(lines, arr_close, new_lines, after=False)

        write_and_validate(self.path, original_text, "".join(lines))

    def set_worktree(self, *, slice_key: str, repo: str, path: str) -> None:
        literal = f'worktree: "{cue_escape(path)}"\n'

        original_text = self.path.read_text()
        lines = original_text.splitlines(keepends=True)
        slice_span = find_key_struct_span(lines, slice_key)
        if slice_span is None:
            die(f"could not locate slice {slice_key!r} in task file text (unexpected)")

        lines, entry_open, entry_close = locate_or_create_repo_entry(lines, slice_span[0], slice_span[1], repo)

        wt_idx = find_line(lines, re.compile(r'^[ \t]*worktree:\s*"'), entry_open + 1, entry_close)
        if wt_idx != -1:
            lines[wt_idx] = literal
        else:
            lines = insert_lines(lines, entry_open, [literal], after=True)

        write_and_validate(self.path, original_text, "".join(lines))

    def add_pr(
        self, *, slice_key: str, repo: str, url: str, status: str, note: str
    ) -> str:
        literal = f'#PR & {{url: "{cue_escape(url)}", status: "{status}", note: "{cue_escape(note)}"}},\n'

        original_text = self.path.read_text()
        lines = original_text.splitlines(keepends=True)
        slice_span = find_key_struct_span(lines, slice_key)
        if slice_span is None:
            die(f"could not locate slice {slice_key!r} in task file text (unexpected)")

        lines, entry_open, entry_close = locate_or_create_repo_entry(lines, slice_span[0], slice_span[1], repo)
        prs_open, prs_close, is_empty = find_array_span(lines, "prs", entry_open, entry_close)

        existing_span = None if is_empty else find_key_struct_span(lines, url, prs_open, prs_close, field_name="url")
        if existing_span is not None:
            lines = lines[: existing_span[0]] + [literal] + lines[existing_span[1] + 1 :]
            action = "updated"
        elif is_empty:
            lines = lines[:prs_open] + ["prs: [\n", literal, "]\n"] + lines[prs_open + 1 :]
            action = "added"
        else:
            lines = insert_lines(lines, prs_close, [literal], after=False)
            action = "added"

        write_and_validate(self.path, original_text, "".join(lines))
        return action

    def write_artifact(
        self, key: str, *, status: str, path: str | None, note: str
    ) -> None:
        text = self.path.read_text()
        entry = artifact_entry_block(key, status, path, note)

        art_match = re.search(r"(?m)^[ \t]*artifacts:\s*\{", text)
        if art_match:
            # Replace an existing entry for this key, if present.
            key_pat = re.compile(r'(?m)^[ \t]*"' + re.escape(key) + r'":\s*\{\n(?:[ \t]+.*\n)*?[ \t]*\}')
            new_text, count = key_pat.subn(entry, text, count=1)
            if count == 0:
                # Insert a new entry right after the artifacts opening brace.
                insert_at = art_match.end()
                new_text = text[:insert_at] + "\n" + entry + text[insert_at:]
            write_and_format(self.path, new_text)
            return

        # No artifacts block yet: create one right after the profile line inside orchestration.
        prof = re.search(r'(?m)^([ \t]*)profile:\s*"[^"]*"', text)
        if not prof:
            die("cannot register toolbelt aid: task has no orchestration.profile (run init first)")
        indent = prof.group(1)
        block = f"\n{indent}artifacts: {{\n{entry}\n{indent}}}"
        new_text = text[: prof.end()] + block + text[prof.end():]
        write_and_format(self.path, new_text)


_PREFIX_WIDTH = 4
_PREFIX_GAP = 10


def _prefix_of(name: str) -> int:
    return int(name.split("-", 1)[0])


def _format_prefix(n: int) -> str:
    return str(n).zfill(_PREFIX_WIDTH)


class TaskLayout:
    """Computes filesystem paths for a directory-backed task. Pure path
    arithmetic plus the directory listing needed to resolve keys/order -
    no file reads/writes here; FsTaskStore owns all I/O."""

    def __init__(self, base: Path) -> None:
        self.base = base

    # ---- top-level scalar/record files ----
    def title_file(self) -> Path: return self.base / "title"
    def status_file(self) -> Path: return self.base / "status"
    def source_file(self) -> Path: return self.base / "source"
    def project_file(self) -> Path: return self.base / "project"
    def context_file(self) -> Path: return self.base / "context"

    # ---- orchestration ----
    def orchestration_dir(self) -> Path: return self.base / "orchestration"
    def profile_file(self) -> Path: return self.orchestration_dir() / "profile"
    def cursor_file(self) -> Path: return self.orchestration_dir() / "cursor"
    def policy_file(self) -> Path: return self.orchestration_dir() / "policy"
    def artifacts_dir(self) -> Path: return self.orchestration_dir() / "artifacts"

    def artifact_dir(self, key: str) -> Path:
        return self.artifacts_dir() / key  # map: stable key, no ordering needed

    def artifact_keys(self) -> list[str]:
        """Existing artifact keys (unordered map: dir names, no .order file)."""
        d = self.artifacts_dir()
        if not d.is_dir():
            return []
        return sorted(p.name for p in d.iterdir() if p.is_dir())

    def artifact_status_file(self, key: str) -> Path:
        return self.artifact_dir(key) / "status"

    def artifact_path_file(self, key: str) -> Path:
        return self.artifact_dir(key) / "path"

    def artifact_note_file(self, key: str) -> Path:
        return self.artifact_dir(key) / "note"

    # ---- decisions: ordered, no natural key, nothing external references them ----
    def decisions_dir(self) -> Path: return self.base / "decisions"

    def decision_dirs(self) -> list[Path]:
        return self._numbered_children(self.decisions_dir())

    def new_decision_dir(self) -> Path:
        return self._append_numbered(self.decisions_dir())

    def decision_date_file(self, decision_dir: Path) -> Path:
        return decision_dir / "date"

    def decision_note_file(self, decision_dir: Path) -> Path:
        return decision_dir / "note"

    def decision_source_file(self, decision_dir: Path) -> Path:
        return decision_dir / "source"

    # ---- plan ----
    def plan_note_file(self) -> Path: return self.base / "plan" / "note"
    def slices_dir(self) -> Path: return self.base / "plan" / "slices"
    def slices_order_file(self) -> Path: return self.slices_dir() / ".order"

    def slice_dir(self, key: str) -> Path:
        """Stable: dirname *is* the key, so depends_on symlinks never dangle."""
        return self.slices_dir() / key

    def slice_dirs(self) -> list[Path]:
        """Existing slices in .order sequence (lexical fallback if .order is missing)."""
        order_file = self.slices_order_file()
        if order_file.exists():
            keys = [ln.strip() for ln in order_file.read_text().splitlines() if ln.strip()]
            return [self.slice_dir(k) for k in keys if self.slice_dir(k).is_dir()]
        return sorted(p for p in self.slices_dir().iterdir() if p.is_dir())

    # ---- per-slice fields ----
    def slice_title_file(self, slice_key: str) -> Path:
        return self.slice_dir(slice_key) / "title"

    def slice_goal_file(self, slice_key: str) -> Path:
        return self.slice_dir(slice_key) / "goal"

    def slice_status_file(self, slice_key: str) -> Path:
        return self.slice_dir(slice_key) / "status"

    def slice_note_file(self, slice_key: str) -> Path:
        return self.slice_dir(slice_key) / "note"

    def slice_repos_file(self, slice_key: str) -> Path:
        return self.slice_dir(slice_key) / "repos"

    def slice_depends_on_dir(self, slice_key: str) -> Path:
        return self.slice_dir(slice_key) / "depends_on"

    def slice_dependency_link(self, slice_key: str, depends_on_key: str) -> Path:
        return self.slice_depends_on_dir(slice_key) / depends_on_key

    def slice_dependency_keys(self, slice_key: str) -> list[str]:
        """Depended-on slice keys, taken from the depends_on symlink dir's entry NAMES
        (not resolved link targets) - absent/empty dir means no dependencies."""
        d = self.slice_depends_on_dir(slice_key)
        if not d.is_dir():
            return []
        return sorted(p.name for p in d.iterdir())

    def slice_repo_work_root(self, slice_key: str) -> Path:
        return self.slice_dir(slice_key) / "repo_work"

    def slice_repo_names(self, slice_key: str) -> list[str]:
        """Existing repo_work repo names (unordered map) - absent/empty dir means none."""
        root = self.slice_repo_work_root(slice_key)
        if not root.is_dir():
            return []
        return sorted(p.name for p in root.iterdir() if p.is_dir())

    def slice_repo_work_dir(self, slice_key: str, repo: str) -> Path:
        return self.slice_dir(slice_key) / "repo_work" / repo

    def slice_repo_worktree_file(self, slice_key: str, repo: str) -> Path:
        return self.slice_repo_work_dir(slice_key, repo) / "worktree"

    def slice_repo_prs_dir(self, slice_key: str, repo: str) -> Path:
        return self.slice_repo_work_dir(slice_key, repo) / "prs"

    def slice_pr_dirs(self, slice_key: str, repo: str) -> list[Path]:
        return self._numbered_children(self.slice_repo_prs_dir(slice_key, repo))

    def new_pr_dir(self, slice_key: str, repo: str) -> Path:
        return self._append_numbered(self.slice_repo_prs_dir(slice_key, repo))

    def pr_url_file(self, pr_dir: Path) -> Path:
        return pr_dir / "url"

    def pr_status_file(self, pr_dir: Path) -> Path:
        return pr_dir / "status"

    def pr_note_file(self, pr_dir: Path) -> Path:
        return pr_dir / "note"

    # ---- steps / final_steps: ordered, keyed, nothing external references them ----
    def steps_dir(self, slice_key: str, *, terminal: bool) -> Path:
        return self.slice_dir(slice_key) / ("final_steps" if terminal else "steps")

    def step_dirs(self, slice_key: str, *, terminal: bool) -> list[Path]:
        return self._numbered_children(self.steps_dir(slice_key, terminal=terminal))

    def step_dir(self, slice_key: str, step_key: str, *, terminal: bool) -> Path:
        for d in self.step_dirs(slice_key, terminal=terminal):
            if d.name.split("-", 1)[-1] == step_key:
                return d
        raise FileNotFoundError(f"step {step_key!r} not found under {self.steps_dir(slice_key, terminal=terminal)}")

    def new_step_dir(self, slice_key: str, step_key: str, *, terminal: bool, after: str | None) -> Path:
        parent = self.steps_dir(slice_key, terminal=terminal)
        if after is None:
            return self._append_numbered(parent, suffix=step_key)
        anchor = self.step_dir(slice_key, after, terminal=terminal)
        return self._insert_numbered_after(parent, anchor, suffix=step_key)

    def step_title_file(self, step_dir: Path) -> Path:
        return step_dir / "title"

    def step_status_file(self, step_dir: Path) -> Path:
        return step_dir / "status"

    def step_note_file(self, step_dir: Path) -> Path:
        return step_dir / "note"

    # ---- private: gapped numeric-prefix ordering, shared by decisions/prs/steps ----
    def _numbered_children(self, parent: Path) -> list[Path]:
        if not parent.is_dir():
            return []
        return sorted((p for p in parent.iterdir() if p.is_dir()), key=lambda p: _prefix_of(p.name))

    def _append_numbered(self, parent: Path, *, suffix: str | None = None) -> Path:
        existing = self._numbered_children(parent)
        next_prefix = _prefix_of(existing[-1].name) + _PREFIX_GAP if existing else _PREFIX_GAP
        name = _format_prefix(next_prefix) + (f"-{suffix}" if suffix else "")
        return parent / name

    def _insert_numbered_after(self, parent: Path, anchor: Path, *, suffix: str | None = None) -> Path:
        existing = self._numbered_children(parent)
        idx = existing.index(anchor)
        before = _prefix_of(anchor.name)
        after = _prefix_of(existing[idx + 1].name) if idx + 1 < len(existing) else before + _PREFIX_GAP
        mid = (before + after) // 2
        if mid == before:
            raise RuntimeError(f"no numbering room between {before} and {after} under {parent}; re-space required")
        name = _format_prefix(mid) + (f"-{suffix}" if suffix else "")
        return parent / name


@lru_cache(maxsize=1)
def _fs_valid_statuses() -> tuple[str, ...]:
    return tuple(cue_def_disjunction_values([TASK_SCHEMA]))


@lru_cache(maxsize=1)
def _fs_valid_pr_statuses() -> tuple[str, ...]:
    return tuple(cue_def_disjunction_values([TASK_SCHEMA], def_name="#PRStatus"))


class FsTaskStore:
    """Experimental directory-backed TaskStore ("everything is a file", /proc-flavored).
    Every real filesystem path is resolved via self.layout (a TaskLayout); this class only
    does file I/O (read/write/mkdir/symlink/rename) on paths it is handed, plus building
    `.tmp-*` staging names as siblings of a layout-resolved path for atomic create/replace
    operations - the one place it names a path segment itself."""

    def __init__(self, base: Path, layout: "TaskLayout | None" = None) -> None:
        self.base = base
        self.layout = layout or TaskLayout(base)

    def describe(self) -> str:
        return f"directory task store at {self.base}"

    # ---- low-level file/record helpers (content parsing/serialization only) ----

    def _atomic_write_text(self, path: Path, content: str) -> None:
        path.parent.mkdir(parents=True, exist_ok=True)
        tmp = path.parent / f".{path.name}.tmp-{uuid4().hex}"
        tmp.write_text(content)
        os.replace(tmp, path)

    def _write_text(self, path: Path, value: str) -> None:
        self._atomic_write_text(path, (value or "") + "\n")

    def _read_text(self, path: Path) -> str:
        if not path.exists():
            return ""
        text = path.read_text()
        return text[:-1] if text.endswith("\n") else text

    def _read_optional_text(self, path: Path) -> str | None:
        if not path.exists():
            return None
        return self._read_text(path)

    def _read_lines(self, path: Path) -> list[str]:
        if not path.exists():
            return []
        return [ln.strip() for ln in path.read_text().splitlines() if ln.strip()]

    def _read_record(self, path: Path) -> dict[str, str]:
        """Parse a 'key: value' per-line record file. Single-line values only - a known,
        deliberate limitation of this experimental backend (no embedded-newline support)."""
        if not path.exists():
            return {}
        record: dict[str, str] = {}
        for line in path.read_text().splitlines():
            if not line.strip():
                continue
            if ":" not in line:
                die(f"malformed record line in {path}: {line!r}")
            key, _, value = line.partition(":")
            record[key.strip()] = value.strip()
        return record

    def _write_record(self, path: Path, fields: dict[str, str | None]) -> None:
        content = "".join(f"{k}: {v}\n" for k, v in fields.items() if v is not None)
        self._atomic_write_text(path, content)

    def _read_bool_field(self, value: str | None, field_desc: str) -> bool:
        if value == "true":
            return True
        if value == "false":
            return False
        die(f"{field_desc}: expected literal 'true' or 'false', got {value!r}")

    def _read_status(self, path: Path, field_desc: str) -> str:
        value = self._read_text(path)
        valid = _fs_valid_statuses()
        if value not in valid:
            die(f"{field_desc}: invalid status {value!r} in {path}; expected one of: {', '.join(valid)}")
        return value

    def _read_pr_status(self, path: Path, field_desc: str) -> str:
        value = self._read_text(path)
        valid = _fs_valid_pr_statuses()
        if value not in valid:
            die(f"{field_desc}: invalid PR status {value!r} in {path}; expected one of: {', '.join(valid)}")
        return value

    # ---- read() ----

    def read(self) -> dict[str, Any]:
        L = self.layout
        result: dict[str, Any] = {
            "title": self._read_text(L.title_file()),
            "status": self._read_status(L.status_file(), "task.status"),
            "source": self._read_record(L.source_file()),
            "project": self._read_record(L.project_file()),
            "context": self._read_text(L.context_file()),
            "decisions": self._read_decisions(),
            "plan": self._read_plan(),
        }
        if L.orchestration_dir().is_dir():
            result["orchestration"] = self._read_orchestration()
        return result

    def _read_decisions(self) -> list[dict[str, Any]]:
        L = self.layout
        return [
            {
                "date": self._read_text(L.decision_date_file(d)),
                "note": self._read_text(L.decision_note_file(d)),
                "source": self._read_text(L.decision_source_file(d)),
            }
            for d in L.decision_dirs()
        ]

    def _read_orchestration(self) -> dict[str, Any]:
        L = self.layout
        cursor_rec = self._read_record(L.cursor_file())
        policy_rec = self._read_record(L.policy_file())
        artifacts: dict[str, Any] = {}
        for key in L.artifact_keys():
            entry: dict[str, Any] = {
                "status": self._read_status(L.artifact_status_file(key), f"orchestration.artifacts[{key}].status"),
            }
            path_val = self._read_optional_text(L.artifact_path_file(key))
            if path_val is not None:
                entry["path"] = path_val
            entry["note"] = self._read_text(L.artifact_note_file(key))
            artifacts[key] = entry
        return {
            "profile": self._read_text(L.profile_file()),
            "cursor": dict(cursor_rec),
            "policy": {
                "coding_execution": {
                    "subagent_required": self._read_bool_field(
                        policy_rec.get("subagent_required"), "policy.subagent_required"
                    ),
                    "lower_power_model_preferred": self._read_bool_field(
                        policy_rec.get("lower_power_model_preferred"), "policy.lower_power_model_preferred"
                    ),
                    "orchestrator_reviews_subagent": self._read_bool_field(
                        policy_rec.get("orchestrator_reviews_subagent"), "policy.orchestrator_reviews_subagent"
                    ),
                }
            },
            "artifacts": artifacts,
        }

    def _read_plan(self) -> dict[str, Any]:
        L = self.layout
        return {
            "note": self._read_text(L.plan_note_file()),
            "slices": [self._read_slice(d) for d in L.slice_dirs()],
        }

    def _read_slice(self, slice_dir: Path) -> dict[str, Any]:
        L = self.layout
        key = slice_dir.name
        entry: dict[str, Any] = {
            "key": key,
            "title": self._read_text(L.slice_title_file(key)),
            "goal": self._read_text(L.slice_goal_file(key)),
            "status": self._read_status(L.slice_status_file(key), f"plan.slices[{key}].status"),
            "note": self._read_text(L.slice_note_file(key)),
        }
        repos = self._read_lines(L.slice_repos_file(key))
        if repos:
            entry["repos"] = repos
        deps = L.slice_dependency_keys(key)
        if deps:
            entry["depends_on"] = deps
        repo_work = self._read_repo_work(key)
        if repo_work:
            entry["repo_work"] = repo_work
        entry["steps"] = [self._read_step(d) for d in L.step_dirs(key, terminal=False)]
        entry["final_steps"] = [self._read_step(d) for d in L.step_dirs(key, terminal=True)]
        return entry

    def _read_repo_work(self, slice_key: str) -> dict[str, Any]:
        L = self.layout
        result: dict[str, Any] = {}
        for repo in L.slice_repo_names(slice_key):
            entry: dict[str, Any] = {}
            wt = self._read_optional_text(L.slice_repo_worktree_file(slice_key, repo))
            if wt is not None:
                entry["worktree"] = wt
            pr_dirs = L.slice_pr_dirs(slice_key, repo)
            if pr_dirs:
                entry["prs"] = [self._read_pr(d) for d in pr_dirs]
            result[repo] = entry
        return result

    def _read_pr(self, pr_dir: Path) -> dict[str, Any]:
        L = self.layout
        return {
            "url": self._read_text(L.pr_url_file(pr_dir)),
            "status": self._read_pr_status(L.pr_status_file(pr_dir), f"pr[{pr_dir.name}].status"),
            "note": self._read_text(L.pr_note_file(pr_dir)),
        }

    def _read_step(self, step_dir: Path) -> dict[str, Any]:
        L = self.layout
        key = step_dir.name.split("-", 1)[-1]
        return {
            "key": key,
            "title": self._read_text(L.step_title_file(step_dir)),
            "status": self._read_status(L.step_status_file(step_dir), f"step[{key}].status"),
            "note": self._read_text(L.step_note_file(step_dir)),
        }

    # ---- mutations ----

    def set_cursor(self, cursor: Cursor) -> None:
        self._write_cursor(cursor)

    def _write_cursor(self, cursor: Cursor) -> None:
        self._write_record(
            self.layout.cursor_file(),
            {"phase": cursor.phase, "slice": cursor.slice, "step": cursor.step},
        )

    def set_profile(self, profile: str, cursor: Cursor) -> None:
        get_profile(profile)
        L = self.layout
        self._write_text(L.profile_file(), profile)
        self._write_cursor(cursor)
        self._write_record(
            L.policy_file(),
            {
                "subagent_required": "true",
                "lower_power_model_preferred": "true",
                "orchestrator_reviews_subagent": "true",
            },
        )

    def add_slice(
        self,
        *,
        key: str,
        title: str,
        goal: str,
        extra_fields: dict[str, list[str]],
        final_steps: list[tuple[str, str]],
        after: str | None,
    ) -> None:
        L = self.layout

        repos: list[str] = []
        depends_on: list[str] = []
        for field_name, values in extra_fields.items():
            if field_name == "repos":
                repos = values
            elif field_name == "depends_on":
                depends_on = values
            else:
                die(
                    f"FsTaskStore.add_slice: unsupported extra field {field_name!r}; "
                    "only 'repos'/'depends_on' are supported by this backend"
                )

        # 1. Stage the slice's own subtree (everything but depends_on, which needs the
        #    slice's real post-rename path) and rename it into place as the LAST step.
        staging = L.slices_dir() / f".tmp-{uuid4().hex}"
        staging.mkdir(parents=True)
        try:
            (staging / "title").write_text(title + "\n")
            (staging / "goal").write_text(goal + "\n")
            (staging / "status").write_text("planned\n")
            (staging / "note").write_text("\n")
            if repos:
                (staging / "repos").write_text("".join(f"{r}\n" for r in repos))
            if final_steps:
                final_steps_dir = staging / "final_steps"
                final_steps_dir.mkdir()
                for i, (step_key, step_title) in enumerate(final_steps, start=1):
                    step_dir = final_steps_dir / f"{_format_prefix(_PREFIX_GAP * i)}-{step_key}"
                    step_dir.mkdir()
                    (step_dir / "title").write_text(step_title + "\n")
                    (step_dir / "status").write_text("planned\n")
                    (step_dir / "note").write_text("\n")
            os.rename(staging, L.slice_dir(key))
        except Exception:
            shutil.rmtree(staging, ignore_errors=True)
            raise

        # 2. depends_on symlinks, now that the slice's real layout-resolved path exists.
        if depends_on:
            L.slice_depends_on_dir(key).mkdir(parents=True, exist_ok=True)
            for dep_key in depends_on:
                L.slice_dependency_link(key, dep_key).symlink_to(f"../../{dep_key}")

        # 3. .order, as a separate final atomic write.
        self._insert_slice_key_in_order(key, after)

    def _insert_slice_key_in_order(self, key: str, after: str | None) -> None:
        order_file = self.layout.slices_order_file()
        existing = (
            [ln.strip() for ln in order_file.read_text().splitlines() if ln.strip()]
            if order_file.exists()
            else []
        )
        if after is not None:
            if after not in existing:
                die(f"--after slice {after!r} not found in slices order (unexpected)")
            existing.insert(existing.index(after) + 1, key)
        else:
            existing.append(key)
        self._atomic_write_text(order_file, "".join(f"{k}\n" for k in existing))

    def add_step(
        self,
        *,
        slice_key: str,
        key: str,
        title: str,
        note: str,
        terminal: bool,
        after: str | None,
    ) -> None:
        target = self.layout.new_step_dir(slice_key, key, terminal=terminal, after=after)
        staging = target.parent / f".tmp-{uuid4().hex}"
        staging.mkdir(parents=True)
        try:
            (staging / "title").write_text(title + "\n")
            (staging / "status").write_text("planned\n")
            (staging / "note").write_text((note or "") + "\n")
            os.rename(staging, target)
        except Exception:
            shutil.rmtree(staging, ignore_errors=True)
            raise

    def set_worktree(self, *, slice_key: str, repo: str, path: str) -> None:
        self._write_text(self.layout.slice_repo_worktree_file(slice_key, repo), path)

    def add_pr(self, *, slice_key: str, repo: str, url: str, status: str, note: str) -> str:
        L = self.layout
        for pr_dir in L.slice_pr_dirs(slice_key, repo):
            if self._read_text(L.pr_url_file(pr_dir)) == url:
                self._write_text(L.pr_status_file(pr_dir), status)
                self._write_text(L.pr_note_file(pr_dir), note)
                return "updated"

        target = L.new_pr_dir(slice_key, repo)
        staging = target.parent / f".tmp-{uuid4().hex}"
        staging.mkdir(parents=True)
        try:
            (staging / "url").write_text(url + "\n")
            (staging / "status").write_text(status + "\n")
            (staging / "note").write_text((note or "") + "\n")
            os.rename(staging, target)
        except Exception:
            shutil.rmtree(staging, ignore_errors=True)
            raise
        return "added"

    def write_artifact(self, key: str, *, status: str, path: str | None, note: str) -> None:
        L = self.layout
        self._write_text(L.artifact_status_file(key), status)
        if path is not None:
            self._write_text(L.artifact_path_file(key), path)
        else:
            path_file = L.artifact_path_file(key)
            if path_file.exists():
                path_file.unlink()
        self._write_text(L.artifact_note_file(key), note or "")


def open_task_store(task_arg: Path) -> TaskStore:
    """Open a task file as a TaskStore. Supports CUE files and, experimentally,
    directory-backed tasks (see FsTaskStore)."""
    if task_arg.suffix == ".cue":
        return CueTaskStore(task_arg)
    if task_arg.is_dir():
        return FsTaskStore(task_arg)
    die(f"unrecognized task storage for {task_arg}")


def run(argv: list[str], *, cwd: Path = ROOT, capture: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(argv, cwd=cwd, text=True, capture_output=capture)


def load_task(task_file: Path) -> dict[str, Any]:
    if not task_file.exists():
        die(missing_task_hint(task_file))
    res = run(["cue", "export", str(task_file), str(TASK_SCHEMA), "-e", "task", "--out", "json"])
    if res.returncode != 0:
        die(f"cue export failed for {task_file}:\n{res.stderr.strip()}")
    try:
        return json.loads(res.stdout)
    except json.JSONDecodeError as exc:
        die(f"cue export returned invalid JSON for {task_file}: {exc}")


@lru_cache(maxsize=1)
def load_profile_contract() -> dict[str, Any]:
    if not PROFILE_CONTRACT.exists():
        die(f"profile contract not found: {PROFILE_CONTRACT}")
    res = run(["cue", "export", str(PROFILE_CONTRACT), "--out", "json"])
    if res.returncode != 0:
        die(f"cue export failed for {PROFILE_CONTRACT}:\n{res.stderr.strip()}")
    try:
        data = json.loads(res.stdout)
    except json.JSONDecodeError as exc:
        die(f"cue export returned invalid JSON for {PROFILE_CONTRACT}: {exc}")
    if "profiles" not in data:
        die(f"profile contract missing profiles: {PROFILE_CONTRACT}")
    return data


def contract_profiles() -> dict[str, dict[str, Any]]:
    """Map hyphenated profile keys (e.g. review-only) to profile objects."""
    profiles: dict[str, dict[str, Any]] = {}
    for entry in load_profile_contract().get("profiles", {}).values():
        key = str(entry.get("key") or "")
        if key:
            profiles[key] = entry
    if not profiles:
        die(f"profile contract has no usable profiles: {PROFILE_CONTRACT}")
    return profiles


def valid_profiles() -> set[str]:
    return set(contract_profiles())


def get_profile(profile_key: str) -> dict[str, Any]:
    profiles = contract_profiles()
    if profile_key not in profiles:
        die(f"unknown pi-job profile {profile_key!r}; expected one of: {', '.join(sorted(profiles))}")
    return profiles[profile_key]


def contract_toolbelt() -> dict[str, dict[str, Any]]:
    """Toolbelt catalog keyed by aid key."""
    toolbelt = load_profile_contract().get("toolbelt") or {}
    return {str(key): entry for key, entry in toolbelt.items()}


def toolbelt_for_profile(profile_key: str) -> list[dict[str, Any]]:
    """Catalog aids whose `suits` includes profile_key, sorted by key."""
    aids = [
        entry
        for entry in contract_toolbelt().values()
        if profile_key in (entry.get("suits") or [])
    ]
    return sorted(aids, key=lambda e: str(e.get("key") or ""))


def task_artifacts(task: dict[str, Any]) -> dict[str, Any]:
    return task.get("orchestration", {}).get("artifacts", {}) or {}


def profile_phases(profile_key: str) -> list[dict[str, Any]]:
    return list(get_profile(profile_key).get("phases") or [])


def find_contract_phase(profile_key: str, phase_key: str) -> dict[str, Any] | None:
    for phase in profile_phases(profile_key):
        if phase.get("key") == phase_key:
            return phase
    return None


def status_value(item: dict[str, Any]) -> str:
    return str(item.get("status") or "").lower()


def current_cursor(task: dict[str, Any]) -> Cursor | None:
    cursor = task.get("orchestration", {}).get("cursor")
    if not cursor:
        return None
    return Cursor(
        phase=str(cursor.get("phase") or ""),
        slice=cursor.get("slice"),
        step=cursor.get("step"),
    )


def slice_work_contract_phase(profile_key: str) -> str | None:
    """Return the profile contract phase that owns task.plan slice work."""
    for phase in profile_phases(profile_key):
        inputs = phase.get("inputs") or []
        if "task.plan.slices" in inputs:
            return str(phase["key"])
    for phase in profile_phases(profile_key):
        key = str(phase.get("key") or "")
        if key in ("implement", "implement_slices"):
            return str(key)
    return None


def profile_value(task: dict[str, Any]) -> str | None:
    profile = task.get("orchestration", {}).get("profile")
    return str(profile) if profile else None


def require_profile(task_file: Path, task: dict[str, Any]) -> str:
    profile = profile_value(task)
    if not profile:
        die(
            "task is not initialized for pi-job: missing task.orchestration.profile\n"
            f"run: ./scripts/pi-job --task {task_file} init --profile <profile>"
        )
    get_profile(profile)
    return profile


def next_cursor(task: dict[str, Any], profile_key: str) -> Cursor | None:
    """Compute the next actionable cursor.

    While task.plan.slices has unfinished work, walk slices/steps under the
    profile's slice-work contract phase, skipping slices with unmet dependencies
    or blocked status. Once all slices are done (or the profile has no
    slice-work phase, e.g. research/review-only/share-only), walk the remaining
    profile phases in contract order, anchored on the saved cursor's phase so
    repeated calls advance monotonically.
    """
    contract_phase = slice_work_contract_phase(profile_key)

    if contract_phase is not None:
        status_map = slice_status_map(task)
        any_unfinished = False
        for task_slice in task.get("plan", {}).get("slices", []):
            if status_value(task_slice) not in STATUS_DONE:
                any_unfinished = True
            if not is_actionable(task_slice, status_map):
                continue
            return slice_cursor(contract_phase, task_slice)
        if any_unfinished:
            return None

    # All slices are done (or this profile has no slice-work phase): walk
    # remaining profile phases in contract order.
    phase_keys = [str(phase.get("key") or "") for phase in profile_phases(profile_key)]
    if not phase_keys:
        return None

    current = current_cursor(task)
    if current is not None and current.phase in phase_keys:
        anchor = phase_keys.index(current.phase)
    elif contract_phase is not None and contract_phase in phase_keys:
        anchor = phase_keys.index(contract_phase)
    else:
        anchor = -1

    next_index = anchor + 1
    if next_index < len(phase_keys):
        return Cursor(phase=phase_keys[next_index])
    return None


def slice_status_map(task: dict[str, Any]) -> dict[str, str]:
    """Return {slice_key: status_value} for all slices in the task."""
    return {str(task_slice.get("key") or ""): status_value(task_slice) for task_slice in task.get("plan", {}).get("slices", [])}


def dependency_satisfied(task_slice: dict[str, Any], status_map: dict[str, str]) -> bool:
    """Return True if all declared dependencies are done/skipped."""
    deps = task_slice.get("depends_on") or []
    return all(status_map.get(k) in STATUS_DONE for k in deps)


def is_actionable(task_slice: dict[str, Any], status_map: dict[str, str]) -> bool:
    """Return True if slice is unfinished, not blocked, and has satisfied dependencies."""
    return (
        status_value(task_slice) not in STATUS_DONE
        and status_value(task_slice) != "blocked"
        and dependency_satisfied(task_slice, status_map)
    )


def unknown_dependency_keys(task: dict[str, Any], status_map: dict[str, str]) -> list[tuple[str, str]]:
    """Return [(slice_key, missing_dep_key)] for unknown dependency references."""
    missing = []
    for task_slice in task.get("plan", {}).get("slices", []):
        slice_key = str(task_slice.get("key") or "")
        for dep_key in (task_slice.get("depends_on") or []):
            if dep_key not in status_map:
                missing.append((slice_key, dep_key))
    return missing


def ready_slices(task: dict[str, Any], profile_key: str) -> list[dict[str, Any]]:
    """Return list of slices where is_actionable() is true, in array order."""
    contract_phase = slice_work_contract_phase(profile_key)
    if contract_phase is None:
        return []
    status_map = slice_status_map(task)
    return [s for s in task.get("plan", {}).get("slices", []) if is_actionable(s, status_map)]


def all_slices_done(task: dict[str, Any]) -> bool:
    """Return True if all slices are done/skipped."""
    return all(status_value(s) in STATUS_DONE for s in task.get("plan", {}).get("slices", []))


def slice_cursor(contract_phase: str, task_slice: dict[str, Any]) -> Cursor:
    """Return the first unfinished step cursor in a slice, or the slice itself if all steps are done."""
    slice_key = str(task_slice.get("key") or "")

    for step in task_slice.get("steps", []):
        if status_value(step) not in STATUS_DONE:
            return Cursor(phase=contract_phase, slice=slice_key, step=str(step.get("key") or ""))

    for step in task_slice.get("final_steps", []):
        if status_value(step) not in STATUS_DONE:
            return Cursor(phase=contract_phase, slice=slice_key, step=str(step.get("key") or ""))

    return Cursor(phase=contract_phase, slice=slice_key)


def print_status(task_file_desc: str, task: dict[str, Any]) -> None:
    print(f"Task: {task.get('title', '<untitled>')}")
    print(f"File: {task_file_desc}")
    print(f"Status: {task.get('status', '<unknown>')}")
    print(f"Contract: {PROFILE_CONTRACT}")
    profile = profile_value(task)
    print(f"Profile: {profile if profile else '<unset>'}")
    if not profile:
        print("Initialization: required")
        print(f"Next: initialize profile with ./scripts/pi-job --task {task_file_desc} init --profile <profile>")
        return
    if profile not in valid_profiles():
        print("Initialization: invalid-profile")
        print(f"Next: choose one of {', '.join(sorted(valid_profiles()))}")
        return
    print("Initialization: ok")
    cursor = current_cursor(task)
    print(f"Cursor: {cursor.label() if cursor else '<unset>'}")
    nxt = next_cursor(task, profile) if profile in valid_profiles() else None
    if nxt is None:
        if all_slices_done(task):
            print("Next: done")
        else:
            print("Next: blocked (no dependency-satisfied slice ready)")
    else:
        print(f"Next: {nxt.label()}")

    # Stale cursor warning
    if cursor is not None and nxt is not None and cursor != nxt:
        print(f"⚠ stored cursor is stale — cursor: {cursor.label()} vs computed next: {nxt.label()}; run `pi-job advance` to resync")

    # Ready slices line
    if profile in valid_profiles():
        ready = ready_slices(task, profile)
        if ready:
            ready_keys = [str(s.get("key") or "") for s in ready]
            print(f"Ready: {', '.join(ready_keys)}")
        else:
            print("Ready: none")

        # Unknown dependency key warnings
        status_map = slice_status_map(task)
        unknown = unknown_dependency_keys(task, status_map)
        for slice_key, dep_key in unknown:
            print(f"⚠ slice '{slice_key}' depends_on unknown slice key '{dep_key}'")


def cursor_block(cursor: Cursor) -> str:
    lines = ["\t\tcursor: {"]
    lines.append(f'\t\t\tphase: "{cursor.phase}"')
    if cursor.slice is not None:
        lines.append(f'\t\t\tslice: "{cursor.slice}"')
    if cursor.step is not None:
        lines.append(f'\t\t\tstep:  "{cursor.step}"')
    lines.append("\t\t}")
    return "\n".join(lines)


def orchestration_block(profile: str, cursor: Cursor) -> str:
    return "\n".join(
        [
            "\torchestration: {",
            f'\t\tprofile: "{profile}"',
            cursor_block(cursor),
            "\t\tpolicy: {",
            "\t\t\tcoding_execution: {",
            "\t\t\t\tsubagent_required:             true",
            "\t\t\t\tlower_power_model_preferred:   true",
            "\t\t\t\torchestrator_reviews_subagent: true",
            "\t\t\t}",
            "\t\t}",
            "\t}",
        ]
    )


def write_and_format(task_file: Path, text: str) -> None:
    task_file.write_text(text)
    fmt = run(["cue", "fmt", str(task_file)])
    if fmt.returncode != 0:
        die(f"cue fmt failed after task update:\n{fmt.stderr.strip()}")


def line_indent(line: str) -> str:
    return line[: len(line) - len(line.lstrip(" \t"))]


def is_blank(line: str) -> bool:
    return line.strip() == ""


def toggles_raw_string(line: str) -> bool:
    """True if this line ends with a lone `\"\"\"` marker (opens or closes a multiline
    string) — a boolean toggle per such line correctly tracks open/close state without
    distinguishing which, since both forms end a line with the same 3-char marker."""
    return line.rstrip().endswith('"""')


def find_block_close(lines: list[str], open_idx: int) -> int:
    """First line after open_idx whose indentation is <= the opening line's, skipping
    blank lines and lines inside a triple-quoted string span."""
    open_indent = line_indent(lines[open_idx])
    in_raw_string = False
    for i in range(open_idx + 1, len(lines)):
        content = lines[i]
        if in_raw_string:
            if toggles_raw_string(content):
                in_raw_string = False
            continue
        if toggles_raw_string(content):
            in_raw_string = True
            continue
        if is_blank(content):
            continue
        if len(line_indent(content)) <= len(open_indent):
            return i
    die(f"could not find closing boundary for block opened at line {open_idx + 1}")


def find_line(lines: list[str], pattern: re.Pattern[str], start: int = 0, end: int | None = None) -> int:
    end = len(lines) if end is None else end
    for i in range(start, end):
        if pattern.search(lines[i]):
            return i
    return -1


def find_local_def(lines: list[str], def_name: str) -> tuple[int, int] | None:
    """Scan raw file text for a top-level declaration of def_name (e.g. '#Slice', '#Status').
    Returns (open_idx, close_idx) or None if not found. For single-line disjunctions,
    both indices point to the same line."""
    pattern = re.compile(r"^" + re.escape(def_name) + r':\s*[{"]')
    open_idx = find_line(lines, pattern)
    if open_idx == -1:
        return None
    # Check if it's a single-line declaration (disjunction like #Status: "a" | "b" | ...)
    if lines[open_idx].rstrip().endswith('"') or "|" in lines[open_idx]:
        return (open_idx, open_idx)
    # Multi-line block: find closing brace
    return (open_idx, find_block_close(lines, open_idx))


def find_key_struct_span(lines, key_value, start=0, end=None, field_name="key") -> tuple[int, int] | None:
    """[open_idx, close_idx] of a `#Slice & {...}`/`#Step & {...}` literal identified by
    `key: "VALUE"` (or any other field name). Handles single-line literals (whole struct on one line — open==close)
    and multi-line ones (scan backward from the key line for the nearest shallower line
    ending in `{`, then find_block_close from there)."""
    end = len(lines) if end is None else end
    key_pat = re.compile(r'\b' + re.escape(field_name) + r':\s*"' + re.escape(key_value) + r'"')
    key_idx = find_line(lines, key_pat, start, end)
    if key_idx == -1:
        return None
    content = lines[key_idx]
    field_str = field_name + ":"
    if "{" in content[: content.index(field_str)]:
        return (key_idx, key_idx)
    key_indent_len = len(line_indent(content))
    for i in range(key_idx - 1, start - 1, -1):
        if is_blank(lines[i]):
            continue
        indent_len = len(line_indent(lines[i]))
        if indent_len < key_indent_len and lines[i].rstrip().endswith("{"):
            return (i, find_block_close(lines, i))
        if indent_len < key_indent_len - 1:
            # Gone too far: less indented than "one level up" from key
            break
    die(f"could not locate opening brace for struct literal with key {key_value!r}")


def find_array_span(lines, field_name, start=0, end=None) -> tuple[int, int, bool]:
    """[open_idx, close_idx, is_empty_inline] for `<field_name>: [...]`. is_empty_inline
    means the field is a single line `field_name: []` — caller must replace, not insert
    around, that line to add the first element."""
    end = len(lines) if end is None else end
    empty_pat = re.compile(r"^[ \t]*" + re.escape(field_name) + r":\s*\[\s*\]\s*,?\s*$")
    idx = find_line(lines, empty_pat, start, end)
    if idx != -1:
        return (idx, idx, True)
    open_pat = re.compile(r"^[ \t]*" + re.escape(field_name) + r":\s*\[\s*$")
    idx = find_line(lines, open_pat, start, end)
    if idx == -1:
        die(f"could not find {field_name!r} array in expected range")
    return (idx, find_block_close(lines, idx), False)


def find_struct_field_span(lines, field_name, start=0, end=None):
    """[open_idx, close_idx, is_empty_inline] for `<field_name>: {...}` — the struct-flavored
    sibling of find_array_span's `[...]`-delimited fields. Returns None (not die) when the
    field doesn't exist — repo_work is optional and callers must create it on first use."""
    end = len(lines) if end is None else end
    empty_pat = re.compile(r"^[ \t]*" + re.escape(field_name) + r":\s*\{\s*\}\s*,?\s*$")
    idx = find_line(lines, empty_pat, start, end)
    if idx != -1:
        return (idx, idx, True)
    open_pat = re.compile(r"^[ \t]*" + re.escape(field_name) + r":\s*\{\s*$")
    idx = find_line(lines, open_pat, start, end)
    if idx == -1:
        return None
    return (idx, find_block_close(lines, idx), False)


def find_map_entry_span(lines, entry_key, start=0, end=None):
    """[open_idx, close_idx, is_empty_inline] for a CUE map entry `"<entry_key>": {...}`
    (a quoted map key, e.g. a repo name inside repo_work) — distinct from
    find_key_struct_span, which matches a `key: "value"` FIELD inside a struct literal."""
    end = len(lines) if end is None else end
    empty_pat = re.compile(r'^[ \t]*"' + re.escape(entry_key) + r'":\s*\{\s*\}\s*,?\s*$')
    idx = find_line(lines, empty_pat, start, end)
    if idx != -1:
        return (idx, idx, True)
    open_pat = re.compile(r'^[ \t]*"' + re.escape(entry_key) + r'":\s*\{\s*$')
    idx = find_line(lines, open_pat, start, end)
    if idx == -1:
        return None
    return (idx, find_block_close(lines, idx), False)


def locate_or_create_repo_entry(lines, slice_open, slice_close, repo):
    """Ensure repo_work: {} exists in [slice_open, slice_close) and that it has a
    "<repo>": {...} entry (worktree absent, prs: [] if freshly created). Returns
    (mutated lines, entry_open, entry_close) — indices valid against the RETURNED lines."""
    rw_span = find_struct_field_span(lines, "repo_work", slice_open, slice_close)
    if rw_span is None:
        lines = lines[: slice_open + 1] + ["repo_work: {}\n"] + lines[slice_open + 1 :]
        rw_open = rw_close = slice_open + 1
        rw_is_empty = True
    else:
        rw_open, rw_close, rw_is_empty = rw_span

    fresh_entry = [f'"{cue_escape(repo)}": {{\n', "prs: []\n", "},\n"]

    if rw_is_empty:
        lines = lines[:rw_open] + ["repo_work: {\n", *fresh_entry, "}\n"] + lines[rw_open + 1 :]
        entry_open = rw_open + 1
        return lines, entry_open, entry_open + len(fresh_entry) - 1

    entry_span = find_map_entry_span(lines, repo, rw_open, rw_close)
    if entry_span is not None:
        entry_open, entry_close, entry_is_empty = entry_span
        if entry_is_empty:
            lines = lines[:entry_open] + fresh_entry + lines[entry_open + 1 :]
            return lines, entry_open, entry_open + len(fresh_entry) - 1
        return lines, entry_open, entry_close

    insert_at = rw_open + 1
    lines = insert_lines(lines, insert_at, fresh_entry, after=False)
    return lines, insert_at, insert_at + len(fresh_entry) - 1


def insert_lines(lines, at_idx, new_lines, *, after: bool) -> list[str]:
    insert_at = at_idx + 1 if after else at_idx
    return lines[:insert_at] + new_lines + lines[insert_at:]


def split_csv(value: str | None) -> list[str]:
    return [v.strip() for v in value.split(",") if v.strip()] if value else []


@dataclass(frozen=True)
class FieldSpec:
    name: str
    optional: bool
    kind: str  # "scalar" | "open_list" | "closed_list"
    closed_items: tuple[tuple[str, str], ...] = ()  # (key, title) pairs, only for kind == "closed_list"


def bracket_delta(text: str) -> int:
    """Return the net {[ count minus }] count for a string, skipping quoted spans (handling \" escapes)."""
    depth = 0
    i = 0
    in_string = False
    while i < len(text):
        c = text[i]
        if in_string:
            if c == "\\" and i + 1 < len(text):
                i += 2
                continue
            if c == '"':
                in_string = False
            i += 1
            continue
        if c == '"':
            in_string = True
            i += 1
            continue
        if c in "{[":
            depth += 1
        elif c in "}]":
            depth -= 1
        i += 1
    return depth


def scan_balanced(text: str, open_idx: int) -> tuple[str, int]:
    """Scan from open_idx (expecting a '{') to matching close, returning (inner_text, close_idx).
    Tracks {[ depth while skipping over double-quoted string contents (handling \" escapes)."""
    depth = 0
    i = open_idx
    in_string = False
    start_inner = open_idx + 1
    while i < len(text):
        c = text[i]
        if in_string:
            if c == "\\" and i + 1 < len(text):
                i += 2
                continue
            if c == '"':
                in_string = False
            i += 1
            continue
        if c == '"':
            in_string = True
            i += 1
            continue
        if c in "{[":
            depth += 1
        elif c in "}]":
            depth -= 1
            if depth == 0:
                return text[start_inner:i], i
        i += 1
    die(f"scan_balanced: unclosed bracket starting at position {open_idx}")


def split_top_level_fields(body: str) -> list[tuple[str, bool, str]]:
    r"""Parse body text and yield (field_name, optional, value_text) for each top-level field.
    Splits at depth-0 lines matching `^\s*(\w+)(\?)?:\s*(.*)$`, accumulating value text across
    continuation lines until depth returns to 0. Uses bracket_delta() to skip quoted spans."""
    lines = body.split("\n")
    fields: list[tuple[str, bool, str]] = []
    i = 0
    while i < len(lines):
        line = lines[i]
        match = re.match(r"^\s*(\w+)(\?)?:\s*(.*)", line)
        if match:
            field_name = match.group(1)
            optional = match.group(2) == "?"
            first_value = match.group(3)
            # Accumulate value text across lines until depth returns to 0
            value_text = first_value
            depth = bracket_delta(first_value)
            i += 1
            while i < len(lines) and depth > 0:
                line_text = lines[i]
                depth += bracket_delta(line_text)
                value_text += "\n" + line_text
                i += 1
            fields.append((field_name, optional, value_text))
        else:
            i += 1
    return fields


def parse_closed_step_items(value_text: str) -> list[tuple[str, str]]:
    """Parse a closed list literal like `[STEP.#x & {...}, STEP.#x & {...}]` and extract
    (key, title) pairs from each item's CUE-syntax struct."""
    items: list[tuple[str, str]] = []
    # Find each {...} struct and extract key and title
    in_struct = False
    struct_text = ""
    for c in value_text:
        if c == "{":
            in_struct = True
            struct_text = "{"
        elif c == "}" and in_struct:
            struct_text += "}"
            # Parse this struct for key and title
            key_match = re.search(r'key:\s*"([^"\\]*(?:\\.[^"\\]*)*)"', struct_text)
            title_match = re.search(r'title:\s*"([^"\\]*(?:\\.[^"\\]*)*)"', struct_text)
            if key_match and title_match:
                key = key_match.group(1)
                title = title_match.group(1)
                items.append((key, title))
            in_struct = False
            struct_text = ""
        elif in_struct:
            struct_text += c
    return items


def cue_def_fields_from(files: list[Path], def_name: str) -> list[FieldSpec]:
    """Shell `cue def` with an explicit file list and parse the extracted definition's
    top-level field list, in declaration order. Reuses the same struct parser as cue_def_fields()."""
    res = run(["cue", "def", *[str(f) for f in files], "-e", def_name])
    if res.returncode != 0:
        die(f"cue def failed for {def_name} in {files}:\n{res.stderr.strip()}")
    return parse_def_struct_fields(res.stdout)


def cue_def_fields(task_file: Path, def_name: str) -> list[FieldSpec]:
    """Shell `cue def <task_file> <TASK_SCHEMA> -e <def_name>` and parse the extracted
    definition's top-level field list, in declaration order. Passing TASK_SCHEMA resolves
    correctly whether this file has its own local #Slice/#Step or relies entirely on the
    shared one — either way this reads the file's REAL unified type, not a guess."""
    return cue_def_fields_from([task_file, TASK_SCHEMA], def_name)


def cue_def_disjunction_values(files: list[Path], def_name: str = "#Status") -> list[str]:
    """Shell `cue def` for the given disjunction def_name (#Status by default) and extract
    all its literal values as a list of strings."""
    res = run(["cue", "def", *[str(f) for f in files], "-e", def_name])
    if res.returncode != 0:
        die(f"cue def failed for {def_name} in {files}:\n{res.stderr.strip()}")
    return re.findall(r'"([^"]*)"', res.stdout)


def split_on_top_level_and(text: str) -> list[str]:
    """Split text on top-level & operators (& that are at bracket depth 0 relative to text's start).
    Tracks {[ depth while skipping over double-quoted string contents (handling \\" escapes).
    Returns a list of operands; if no & at depth 0, returns [text]."""
    operands: list[str] = []
    current: list[str] = []
    depth = 0
    i = 0
    in_string = False

    while i < len(text):
        c = text[i]
        if in_string:
            current.append(c)
            if c == "\\" and i + 1 < len(text):
                current.append(text[i + 1])
                i += 2
                continue
            if c == '"':
                in_string = False
            i += 1
            continue
        if c == '"':
            in_string = True
            current.append(c)
            i += 1
            continue
        if c in "{[":
            depth += 1
            current.append(c)
        elif c in "}]":
            depth -= 1
            current.append(c)
        elif c == "&" and depth == 0:
            operand_text = "".join(current).strip()
            if operand_text:
                operands.append(operand_text)
            current = []
            i += 1
            while i < len(text) and text[i] in " \t\n":
                i += 1
            continue
        else:
            current.append(c)
        i += 1

    operand_text = "".join(current).strip()
    if operand_text:
        operands.append(operand_text)

    return operands


def resolve_field_spec(name: str, optional: bool, value_text: str) -> FieldSpec:
    """Resolve a field's FieldSpec by splitting on top-level & operators and classifying each operand.
    Returns the most specific: closed_list > open_list > scalar. Closed_list is returned if any
    operand is a closed list; open_list if any is open; otherwise scalar."""
    operands = split_on_top_level_and(value_text)

    closed_list_spec: FieldSpec | None = None
    has_open_list = False

    for operand in operands:
        operand = operand.strip()
        if operand.startswith("[..."):
            has_open_list = True
        elif operand.startswith("["):
            if closed_list_spec is None:
                items = tuple(parse_closed_step_items(operand))
                closed_list_spec = FieldSpec(name, optional, "closed_list", closed_items=items)

    if closed_list_spec is not None:
        return closed_list_spec
    elif has_open_list:
        return FieldSpec(name, optional, "open_list")
    else:
        return FieldSpec(name, optional, "scalar")


def parse_def_struct_fields(text: str) -> list[FieldSpec]:
    """Parse `cue def`'s CUE-syntax output. This text is machine-generated and compact
    (no prose, no multiline strings, no author-formatting variance) — a real bracket-depth
    scanner is tractable and safe here, unlike scanning an arbitrary task file's freeform
    text. Skips over double-quoted string spans (respecting \\" escapes) so a title
    containing literal brackets can't confuse the depth counter. Only extracts the OUTER
    struct's direct fields — nested `let STATUS = {...}` / `let STEP = {...}` hoisted
    cross-reference blocks (emitted after the main struct) are ignored; field VALUES that
    reference them (`status: STATUS.#x`) are just opaque scalar leaves to this parser.

    Handles unified field values (e.g. from cue def when both the local file and shared
    schema contribute to the same field) by splitting on top-level & operators and
    classifying each operand independently, resolving to the most specific."""
    open_idx = text.index("{")
    body, _ = scan_balanced(text, open_idx)  # returns (inner_text, close_idx); see helper below
    fields: list[FieldSpec] = []
    for name, optional, value_text in split_top_level_fields(body):
        value_text = value_text.strip()
        fields.append(resolve_field_spec(name, optional, value_text))
    return fields


def parse_def_struct_fields_from_raw(lines: list[str], open_idx: int, close_idx: int) -> list[FieldSpec]:
    """Like parse_def_struct_fields, but parses a task file's OWN local struct block
    directly from its raw text (lines[open_idx:close_idx+1], e.g. `#Slice: {...}`)
    instead of shelling `cue def` on the file alone. This sidesteps a real failure mode:
    if the file already had another type (e.g. #Step) migrated away in an earlier pass,
    resolving the remaining local block ALONE via `cue def` fails with a
    'reference not found' error, since the block still references that type structurally
    (e.g. final_steps' items are `#Step & {...}` literals). Parsing the raw text directly
    only needs the literal field/value syntax, never CUE type resolution, so it works
    regardless of what else has or hasn't been migrated away."""
    text = "\n".join(lines[open_idx : close_idx + 1])
    return parse_def_struct_fields(text)


def cue_escape(s: str) -> str:
    return s.replace("\\", "\\\\").replace('"', '\\"')


def step_literal(key: str, title: str, *, status: str = "planned", note: str = "") -> str:
    return (
        f'#Step & {{key: "{cue_escape(key)}", title: "{cue_escape(title)}", '
        f'status: "{status}", note: "{cue_escape(note)}"}},\n'
    )


def slice_literal(*, key: str, title: str, goal: str, extra_fields: dict[str, list[str]], final_steps: list[tuple[str, str]]) -> str:
    """extra_fields maps a non-baseline #Slice field name to its plain string values,
    for whatever fields this file's #Slice schema declares and the caller resolved
    values for - driven entirely by cue_def_fields(), no hardcoded field list. Rendered
    here as a CUE string-list literal; callers pass plain data, not CUE syntax. final_steps
    is [(key, title), ...] - either copied from the schema's closed-list literal, or empty
    when the schema's final_steps is open."""
    lines = [
        "#Slice & {\n",
        f'key: "{cue_escape(key)}"\n',
        f'title: "{cue_escape(title)}"\n',
        f'goal: "{cue_escape(goal)}"\n',
        'status: "planned"\n',
        'note: ""\n',
    ]
    for field_name, values in extra_fields.items():
        rendered = "[" + ", ".join(f'"{cue_escape(v)}"' for v in values) + "]"
        lines.append(f"{field_name}: {rendered}\n")
    lines.append("steps: []\n")
    if final_steps:
        lines.append("final_steps: [\n")
        lines += [step_literal(k, t) for k, t in final_steps]
        lines.append("]\n")
    else:
        lines.append("final_steps: []\n")
    lines.append("},\n")
    return "".join(lines)


def write_and_validate(task_file: Path, original_text: str, new_text: str) -> None:
    task_file.write_text(new_text)
    fmt_res = run(["cue", "fmt", str(task_file)])
    if fmt_res.returncode != 0:
        task_file.write_text(original_text)
        die(f"generated CUE failed to format and was rolled back:\n{fmt_res.stderr.strip()}")
    export_res = run(["cue", "export", str(task_file), str(TASK_SCHEMA), "-e", "task", "--out", "json"])
    if export_res.returncode != 0:
        task_file.write_text(original_text)
        die(f"generated CUE failed validation and was rolled back:\n{export_res.stderr.strip()}")


def artifact_entry_block(key: str, status: str, path: str | None, note: str) -> str:
    lines = [f'\t\t\t"{key}": {{', f'\t\t\t\tstatus: "{status}"']
    if path:
        lines.append(f'\t\t\t\tpath:   "{path}"')
    lines.append(f'\t\t\t\tnote:   "{note}"')
    lines.append("\t\t\t}")
    return "\n".join(lines)


def toolbelt_add(store: TaskStore, task: dict[str, Any], args: argparse.Namespace) -> None:
    key = args.key
    if not key:
        die("toolbelt add requires an aid key, e.g. `toolbelt add sequence-diagram`")
    catalog = contract_toolbelt()
    if key not in catalog:
        die(f"unknown toolbelt aid {key!r}; expected one of: {', '.join(sorted(catalog))}")
    store.write_artifact(key, status=args.status, path=args.path, note=args.note)
    print(f"registered toolbelt aid: {key} [{args.status}]")


def toolbelt_block(task: dict[str, Any], profile_key: str) -> list[str]:
    aids = toolbelt_for_profile(profile_key)
    if not aids:
        return ["", "Toolbelt (planning aids): none suited to this profile."]
    artifacts = task_artifacts(task)
    lines = ["", "Toolbelt (planning aids) — register with `pi-job toolbelt add <key>`:"]
    for aid in aids:
        key = str(aid.get("key") or "")
        registered = artifacts.get(key)
        status = str(registered.get("status")) if registered else "not registered"
        lines.append(f"- {key} [{status}] — {aid.get('purpose', '')}")
    return lines


def find_current_slice(task: dict[str, Any], cursor: Cursor) -> dict[str, Any] | None:
    for task_slice in task.get("plan", {}).get("slices", []):
        if task_slice.get("key") == cursor.slice:
            return task_slice
    return None


def find_current_step(task_slice: dict[str, Any] | None, cursor: Cursor) -> dict[str, Any] | None:
    if not task_slice or not cursor.step:
        return None
    for group in ("steps", "final_steps"):
        for step in task_slice.get(group, []):
            if step.get("key") == cursor.step:
                return step
    return None


def blocking_incomplete_step(task: dict[str, Any], cursor: Cursor | None) -> str | None:
    """Return a reason string if the saved cursor's step is not done/skipped, else None."""
    if cursor is None or not cursor.step:
        return None
    task_slice = find_current_slice(task, cursor)
    step = find_current_step(task_slice, cursor)
    if step is None:
        return None
    if status_value(step) not in STATUS_DONE:
        status = step.get("status") or "<unset>"
        return f"current cursor step is not done: {cursor.label()} (status: {status})"
    return None


def phase_owner(profile_key: str, cursor: Cursor) -> str:
    phase = find_contract_phase(profile_key, cursor.phase)
    if not phase:
        die(f"unknown contract phase {cursor.phase!r} for profile {profile_key!r}")
    return str(phase.get("owner") or "orchestrator")


def enforce_owner_policy(
    owner: str,
    *,
    policy: dict[str, Any],
    contract_policy: dict[str, Any],
) -> None:
    subagent_required = policy.get("subagent_required", contract_policy.get("subagent_required", True))
    exceptions = contract_policy.get("exceptions") or []
    if owner == "subagent" and not subagent_required and not exceptions:
        die(
            "contract phase owner is subagent but coding_execution.subagent_required is false "
            "without a recorded exception"
        )
    if owner == "subagent" and subagent_required:
        return


def build_plan(task_file: Path, task: dict[str, Any], profile_key: str) -> str:
    profile = get_profile(profile_key)
    cursor = current_cursor(task)
    nxt = next_cursor(task, profile_key)
    lines = [
        "PI-JOB PROFILE PLAN",
        "",
        f"Task file: {task_file}",
        f"Contract: {PROFILE_CONTRACT}",
        f"Profile: {profile_key} ({profile.get('title', '')})",
        f"Description: {profile.get('description', '')}",
        f"Task cursor: {cursor.label() if cursor else '<unset>'}",
        f"Next slice step: {nxt.label() if nxt else 'done'}",
        "",
        "Profile phases:",
    ]
    for index, phase in enumerate(profile_phases(profile_key), start=1):
        key = str(phase.get("key") or "")
        owner = str(phase.get("owner") or "orchestrator")
        required = "required" if phase.get("required", True) else "optional"
        marker = ""
        if cursor and cursor.phase == key:
            marker = "  <-- current"
        elif nxt and nxt.phase == key:
            marker = "  <-- next"
        lines.append(f"{index:2}. {key} [{owner}/{required}] {phase.get('title', '')}{marker}")
        validators = phase.get("validators") or []
        if validators:
            lines.append(f"    validators: {', '.join(validators)}")
        skip_rule = phase.get("skip_rule")
        if skip_rule:
            lines.append(f"    skip_rule: {skip_rule}")
        guidance = phase.get("guidance")
        if guidance:
            lines.append(f"    guidance: {guidance}")
        gates = phase.get("artifact_gates") or []
        for gate in gates:
            req = "required" if gate.get("required") else "optional"
            lines.append(f"    artifact: {gate.get('key')} ({req}) when {gate.get('when')}")
    lines += [
        "",
        "Orchestrator todo instruction:",
        "- Use the session todo capability to track this profile plan.",
        "- Create one todo per required profile phase (and optional phases you intend to run).",
        "- Mark the current/next phase in_progress; mark completed phases done as evidence lands.",
        "- Keep todos aligned with pi-job status/next; do not invent parallel plans outside the contract.",
        "",
        "Note: next/advance walk task.plan slices under the profile's slice-work contract phase.",
    ]
    lines += toolbelt_block(task, profile_key)
    return "\n".join(lines)


def build_instruction(task_file: Path, task: dict[str, Any], cursor: Cursor) -> str:
    profile_key = require_profile(task_file, task)
    policy = task.get("orchestration", {}).get("policy", {}).get("coding_execution", {})
    contract_policy = get_profile(profile_key).get("policies", {}).get("coding_execution") or {}
    task_slice = find_current_slice(task, cursor)
    step = find_current_step(task_slice, cursor)
    contract_phase = find_contract_phase(profile_key, cursor.phase)
    owner = phase_owner(profile_key, cursor)
    enforce_owner_policy(
        owner,
        policy=policy,
        contract_policy=contract_policy,
    )
    title = step.get("title") if step else task_slice.get("title") if task_slice else cursor.label()
    note = step.get("note") if step else task_slice.get("note") if task_slice else ""

    lines = [
        "PI-JOB EXECUTION INSTRUCTION",
        "",
        f"Task file: {task_file}",
        f"Repository root: {ROOT}",
        f"Contract: {PROFILE_CONTRACT}",
        f"Profile: {profile_key}",
        f"Current cursor: {cursor.label()}",
        f"Owner: {owner}",
    ]
    if task_slice:
        lines.append(f"Slice: {task_slice.get('key')} — {task_slice.get('title', '<untitled>')}")
        slice_goal = task_slice.get("goal")
        if slice_goal:
            lines.append(f"Slice goal: {slice_goal}")
        slice_note = task_slice.get("note")
        if slice_note:
            lines.append(f"Slice note: {slice_note}")
    if step:
        lines.append(f"Step: {step.get('key')} — {step.get('title', '<untitled>')}")
    lines.append(f"Step title: {title or '<untitled>'}")
    if note:
        lines.append(f"Step note: {note}")
    if contract_phase:
        lines += [
            f"Contract phase: {contract_phase.get('key')} — {contract_phase.get('title', '')}",
            f"Contract owner: {contract_phase.get('owner', owner)}",
        ]
        validators = contract_phase.get("validators") or []
        if validators:
            lines.append(f"Validators: {', '.join(validators)}")
        inputs = contract_phase.get("inputs") or []
        if inputs:
            lines.append(f"Inputs: {', '.join(inputs)}")
        outputs = contract_phase.get("outputs") or []
        if outputs:
            lines.append(f"Outputs: {', '.join(outputs)}")
        skip_rule = contract_phase.get("skip_rule")
        if skip_rule:
            lines.append(f"Skip rule: {skip_rule}")
        guidance = contract_phase.get("guidance")
        if guidance:
            lines.append(f"Guidance: {guidance}")
        for gate in contract_phase.get("artifact_gates") or []:
            req = "required" if gate.get("required") else "optional"
            lines.append(
                f"Artifact gate: {gate.get('key')} ({req}) — {gate.get('output')} when {gate.get('when')}"
            )

    subagent_required = policy.get("subagent_required", contract_policy.get("subagent_required", True))
    lower_power = policy.get(
        "lower_power_model_preferred", contract_policy.get("lower_power_model_preferred", True)
    )
    reviews = policy.get(
        "orchestrator_reviews_subagent", contract_policy.get("orchestrator_reviews_subagent", True)
    )
    lines += [
        "",
        "Execution policy:",
        f"- subagent_required: {subagent_required}",
        f"- lower_power_model_preferred: {lower_power}",
        f"- orchestrator_reviews_subagent: {reviews}",
    ]
    todo_lines = [
        "",
        "Todo tracking:",
        "- Keep session todos aligned with `pi-job plan` for this profile.",
        f"- Set the todo for cursor {cursor.label()} to in_progress before executing.",
        "- Mark that todo completed only after validators/artifact gates for the step are satisfied or a skip reason is recorded.",
    ]
    if owner == "subagent":
        lines += [
            "",
            "Orchestrator instruction:",
            "- Choose an appropriate lower-cost model using judgement.",
            "- Run this step in a subagent.",
            "- Give the subagent the prompt below exactly, plus any runtime tool context it needs.",
            "- Review the subagent result before running pi-job advance.",
            *todo_lines,
            "",
            "Subagent prompt:",
            f"Read the task file first: {task_file}",
            f"Read the profile contract: {PROFILE_CONTRACT}",
            f"Execute only cursor {cursor.label()}.",
            "Return changed files, commands run, verification evidence, and unresolved risks.",
            "Do not advance the task record unless this cursor step explicitly asks for task-record updates.",
        ]
    else:
        lines += [
            "",
            "Orchestrator instruction:",
            "- Execute this step in the main orchestration session.",
            "- Do not skip required artifacts or validators from the task/profile contract.",
            "- Run pi-job advance only after the step evidence is recorded or a blocker is written down.",
            *todo_lines,
        ]
    if cursor.phase in ("select_toolbelt", "plan_slices"):
        lines += toolbelt_block(task, profile_key)
    return "\n".join(lines)


def cmd_status(args: argparse.Namespace) -> None:
    store = open_task_store(args.task.resolve())
    print_status(str(args.task.resolve()), store.read())


def cmd_next(args: argparse.Namespace) -> None:
    store = open_task_store(args.task.resolve())
    task = store.read()
    profile_key = require_profile(args.task.resolve(), task)
    if args.all:
        ready = ready_slices(task, profile_key)
        if ready:
            contract_phase = slice_work_contract_phase(profile_key)
            for s in ready:
                cursor = slice_cursor(contract_phase, s)
                print(cursor.label())
        else:
            if all_slices_done(task):
                print("done")
            else:
                print("blocked: no dependency-satisfied slice ready")
    else:
        cursor = next_cursor(task, profile_key)
        if cursor is None:
            if all_slices_done(task):
                print("done")
            else:
                print("blocked: no dependency-satisfied slice ready")
            return
        print(cursor.label())


def cmd_advance(args: argparse.Namespace) -> None:
    store = open_task_store(args.task.resolve())
    task = store.read()
    profile_key = require_profile(args.task.resolve(), task)

    if not args.dry_run:
        block_reason = blocking_incomplete_step(task, current_cursor(task))
        if block_reason and not args.force:
            die(
                f"{block_reason}\n"
                "mark the step done/skipped in the task file, or re-run with "
                "--force --reason '<why>' to record an explicit skip"
            )
        if args.force and not args.reason:
            die("--force requires --reason '<why>' to record why the step is being skipped")

    if args.phase:
        cursor = Cursor(args.phase, args.slice, args.step)
        if find_contract_phase(profile_key, cursor.phase) is None:
            die(f"unknown contract phase {cursor.phase!r} for profile {profile_key!r}")
    else:
        cursor = next_cursor(task, profile_key)
    if cursor is None:
        if all_slices_done(task):
            die("task has no next cursor (all slices are done)")
        else:
            die("no dependency-satisfied slice is ready; use --phase/--slice/--step to jump explicitly")
    if args.dry_run:
        print(cursor_block(cursor))
        return
    store.set_cursor(cursor)
    if args.force and args.reason:
        print(f"forced advance (skip reason: {args.reason})")
    print(f"advanced cursor: {cursor.label()}")


def cmd_instruction(args: argparse.Namespace) -> None:
    task_file = args.task.resolve()
    store = open_task_store(task_file)
    task = store.read()
    profile_key = require_profile(task_file, task)
    cursor = current_cursor(task) if args.current else next_cursor(task, profile_key)
    if cursor is None:
        die("task has no cursor for instruction")
    print(build_instruction(task_file, task, cursor))


def cmd_plan(args: argparse.Namespace) -> None:
    task_file = args.task.resolve()
    store = open_task_store(task_file)
    task = store.read()
    profile = require_profile(task_file, task)
    print(build_plan(task_file, task, profile))


def slice_counts(task_slice: dict[str, Any]) -> tuple[int, int]:
    steps = list(task_slice.get("steps", [])) + list(task_slice.get("final_steps", []))
    done = sum(1 for s in steps if status_value(s) in STATUS_DONE)
    return done, len(steps)


def step_line(step: dict[str, Any], *, terminal: bool, current_step: str | None) -> str:
    st = status_value(step)
    glyph = "·" if (terminal and st not in STATUS_DONE) else GLYPH.get(st, "○")
    key = str(step.get("key") or "")
    suffix = "   ← current" if current_step is not None and key == current_step else ""
    return f"    {glyph} {key}{suffix}"


def cmd_show(args: argparse.Namespace) -> None:
    task_file = args.task.resolve()
    store = open_task_store(task_file)
    task = store.read()
    profile_key = require_profile(task_file, task)
    cursor = current_cursor(task)
    status_filter = set(args.status.split(",")) if args.status else None

    lines = [f"{task.get('title', '<untitled>')}     profile: {profile_key}"]
    if cursor:
        lines.append(f"cursor → {cursor.slice or '-'} / {cursor.step or '-'}")
    lines.append("")

    slices = task.get("plan", {}).get("slices", [])
    status_map = slice_status_map(task)
    done_slices = done_steps = total_steps = 0
    for task_slice in slices:
        st = status_value(task_slice)
        d, t = slice_counts(task_slice)
        done_steps += d
        total_steps += t
        if st in STATUS_DONE:
            done_slices += 1
        if status_filter and st not in status_filter:
            continue
        is_current = bool(cursor and cursor.slice == task_slice.get("key"))
        glyph = GLYPH["in_progress"] if is_current else GLYPH.get(st, "○")
        repos = ", ".join(task_slice.get("repos", []) or [])
        lines.append(f"{glyph} {str(task_slice.get('key') or ''):<22} [{d}/{t}] {repos}".rstrip())

        # Render dependencies if present
        deps = task_slice.get("depends_on") or []
        if deps:
            dep_strs = []
            for dep_key in deps:
                dep_status = status_map.get(dep_key, "missing")
                dep_strs.append(f"{dep_key}:{dep_status}")
            deps_line = f"    deps: [{', '.join(dep_strs)}]"
            if not is_actionable(task_slice, status_map):
                deps_line += "  (not ready)"
            lines.append(deps_line)

        repo_work = task_slice.get("repo_work") or {}
        for repo_name in sorted(repo_work):
            work = repo_work[repo_name] or {}
            worktree = work.get("worktree") or "not set"
            lines.append(f"    repo_work[{repo_name}]: worktree={worktree}")
            for pr in work.get("prs", []) or []:
                note_suffix = f" — {pr.get('note')}" if pr.get("note") else ""
                lines.append(f"        pr {pr.get('status')} {pr.get('url')}{note_suffix}")

        if args.all or is_current or st in ("in_progress", "blocked"):
            current_step = cursor.step if is_current and cursor else None
            for step in task_slice.get("steps", []):
                lines.append(step_line(step, terminal=False, current_step=current_step))
            for step in task_slice.get("final_steps", []):
                lines.append(step_line(step, terminal=True, current_step=current_step))

    lines += ["", f"{done_slices}/{len(slices)} slices · {done_steps}/{total_steps} steps", "— toolbelt —"]
    artifacts = task_artifacts(task)
    if not artifacts:
        lines.append("no aids registered")
    else:
        for key, art in artifacts.items():
            g = GLYPH.get(str(art.get("status")), "○")
            lines.append(f"{g} {key}   {art.get('path', '')}".rstrip())
    print("\n".join(lines))


def cmd_toolbelt(args: argparse.Namespace) -> None:
    store = open_task_store(args.task.resolve())
    task = store.read()
    profile_key = require_profile(args.task.resolve(), task)
    if args.action == "add":
        toolbelt_add(store, task, args)
        return
    aids = toolbelt_for_profile(profile_key)
    print(f"Toolbelt aids suited to profile {profile_key}:")
    if not aids:
        print("  (none — this profile suggests no planning aids)")
        return
    artifacts = task_artifacts(task)
    for aid in aids:
        key = str(aid.get("key") or "")
        registered = artifacts.get(key)
        status = str(registered.get("status")) if registered else "not registered"
        print(f"  {key} [{status}] — {aid.get('title')}: {aid.get('purpose')}")


def cmd_init(args: argparse.Namespace) -> None:
    store = open_task_store(args.task.resolve())
    task = store.read()
    get_profile(args.profile)
    cursor = next_cursor(task, args.profile)
    if cursor is None:
        if all_slices_done(task):
            cursor = Cursor("done")
        else:
            # No ready slices: unmet dependencies or cycles at init time.
            die("no slice is dependency-satisfied yet; check depends_on for a forward reference or cycle among the first slices")
    if args.dry_run:
        print(orchestration_block(args.profile, cursor))
        return
    store.set_profile(args.profile, cursor)
    print(f"initialized profile: {args.profile}")
    print(f"cursor: {cursor.label()}")


def cmd_scaffold(args: argparse.Namespace) -> None:
    task_file = args.task.resolve()
    content = example_task_cue(title=args.title)
    if args.dry_run:
        print(content, end="" if content.endswith("\n") else "\n")
        return
    if task_file.exists() and not args.force:
        die(f"task file already exists: {task_file}\npass --force to overwrite, or choose another --task path")
    task_file.parent.mkdir(parents=True, exist_ok=True)
    write_and_format(task_file, content)
    print(f"scaffolded task file: {task_file}")
    print("next: edit project/source/plan, then run:")
    print(f"  pi-job --task {task_file} init --profile <profile>")
    print(f"  pi-job --task {task_file} plan")


BASELINE_SLICE_FIELDS = {"key", "title", "goal", "status", "note", "steps", "final_steps"}
CLI_FILLABLE_SLICE_FIELDS = {"repos": lambda args: split_csv(args.repos), "depends_on": lambda args: split_csv(args.depends_on)}


def cmd_add_slice(args: argparse.Namespace) -> None:
    task_file = args.task.resolve()
    store = open_task_store(task_file)
    task = store.read()

    status_map = slice_status_map(task)
    if args.key in status_map:
        die(f"slice key already exists: {args.key!r}")
    if args.after and args.after not in status_map:
        die(f"--after slice not found: {args.after!r}; known: {', '.join(status_map)}")

    fields = cue_def_fields(task_file, "#Slice")
    by_name = {f.name: f for f in fields}
    for required in ("key", "title", "goal", "status", "note", "steps", "final_steps"):
        if required not in by_name:
            die(f"this file's #Slice schema is missing expected field {required!r}; unsupported shape, add the slice by hand")

    extra_fields: dict[str, list[str]] = {}
    for f in fields:
        if f.name in BASELINE_SLICE_FIELDS:
            continue
        if f.name not in CLI_FILLABLE_SLICE_FIELDS:
            if not f.optional:
                die(f"this file's #Slice requires field {f.name!r}, which add-slice doesn't know how to fill; add the slice by hand")
            continue  # optional and unsupported: fine to omit
        values = CLI_FILLABLE_SLICE_FIELDS[f.name](args)
        if not f.optional and not values:
            die(f"this file's #Slice requires {f.name!r}; pass --{f.name.replace('_', '-')} v1,v2,...")
        if values:
            extra_fields[f.name] = values
    for cli_field, getter in CLI_FILLABLE_SLICE_FIELDS.items():
        if cli_field not in by_name and getter(args):
            die(f"this file's #Slice schema has no {cli_field!r} field; drop --{cli_field.replace('_', '-')}, or add the field to the schema first")

    final_steps = list(by_name["final_steps"].closed_items) if by_name["final_steps"].kind == "closed_list" else []

    literal = slice_literal(key=args.key, title=args.title, goal=args.goal, extra_fields=extra_fields, final_steps=final_steps)
    if args.dry_run:
        print(literal, end="")
        return

    store.add_slice(key=args.key, title=args.title, goal=args.goal, extra_fields=extra_fields, final_steps=final_steps, after=args.after)
    print(f"added slice: {args.key}")


BASELINE_STEP_FIELDS = {"key", "title", "status", "note"}


def cmd_add_step(args: argparse.Namespace) -> None:
    task_file = args.task.resolve()
    store = open_task_store(task_file)
    task = store.read()

    slices = task.get("plan", {}).get("slices", [])
    task_slice = next((s for s in slices if s.get("key") == args.slice), None)
    if task_slice is None:
        known = ", ".join(str(s.get("key") or "") for s in slices)
        die(f"slice not found: {args.slice!r}; known slice keys: {known}")

    step_fields = cue_def_fields(task_file, "#Step")
    for f in step_fields:
        if f.name not in BASELINE_STEP_FIELDS and not f.optional:
            die(f"this file's #Step requires field {f.name!r}, which add-step doesn't know how to fill; add the step by hand")
    for required in BASELINE_STEP_FIELDS:
        if required not in {f.name for f in step_fields}:
            die(f"this file's #Step schema is missing expected field {required!r}; unsupported shape, add the step by hand")

    existing = {str(s.get("key") or "") for s in task_slice.get("steps", [])} | {
        str(s.get("key") or "") for s in task_slice.get("final_steps", [])
    }
    if args.key in existing:
        die(f"step key already exists in slice {args.slice!r}: {args.key!r}")

    group = "final_steps" if args.final else "steps"
    group_keys = [str(s.get("key") or "") for s in task_slice.get(group, [])]
    if args.after and args.after not in group_keys:
        die(f"--after step not found in {args.slice!r}.{group}: {args.after!r}; known: {', '.join(group_keys) or '(none)'}")

    literal = step_literal(args.key, args.title, note=args.note or "")
    if args.dry_run:
        print(literal, end="")
        return

    store.add_step(slice_key=args.slice, key=args.key, title=args.title, note=args.note or "", terminal=args.final, after=args.after)
    print(f"added step: {args.slice}/{args.key} ({group})")


def cmd_set_worktree(args: argparse.Namespace) -> None:
    task_file = args.task.resolve()
    store = open_task_store(task_file)
    task = store.read()
    slices = task.get("plan", {}).get("slices", [])
    if not any(s.get("key") == args.slice for s in slices):
        known = ", ".join(str(s.get("key") or "") for s in slices)
        die(f"slice not found: {args.slice!r}; known slice keys: {known}")

    literal = f'worktree: "{cue_escape(args.path)}"\n'
    if args.dry_run:
        print(literal, end="")
        return

    store.set_worktree(slice_key=args.slice, repo=args.repo, path=args.path)
    print(f"set worktree: {args.slice}/{args.repo} -> {args.path}")


def cmd_add_pr(args: argparse.Namespace) -> None:
    task_file = args.task.resolve()
    store = open_task_store(task_file)
    task = store.read()
    slices = task.get("plan", {}).get("slices", [])
    if not any(s.get("key") == args.slice for s in slices):
        known = ", ".join(str(s.get("key") or "") for s in slices)
        die(f"slice not found: {args.slice!r}; known slice keys: {known}")

    note = args.note or ""
    literal = f'#PR & {{url: "{cue_escape(args.url)}", status: "{args.status}", note: "{cue_escape(note)}"}},\n'
    if args.dry_run:
        print(literal, end="")
        return

    action = store.add_pr(slice_key=args.slice, repo=args.repo, url=args.url, status=args.status, note=note)
    print(f"{action} PR: {args.slice}/{args.repo} {args.url} [{args.status}]")


LOCAL_DEF_NAMES = ("#Status", "#Step", "#Decision", "#Artifact", "#Slice")


def cmd_migrate_task(args: argparse.Namespace) -> None:
    """Diagnose a task file's local schema declarations against the shared task-schema.cue
    and print migration guidance. Read-only: never modifies the file."""
    task_file = args.task.resolve()
    if not task_file.exists():
        die(missing_task_hint(task_file))

    # Read the file's raw text once for line-based scanning and grepping
    raw_text = task_file.read_text()
    lines = raw_text.splitlines(keepends=False)

    # Scan for each of the 5 known def names
    found_defs: dict[str, tuple[int, int]] = {}
    for def_name in LOCAL_DEF_NAMES:
        span = find_local_def(lines, def_name)
        if span:
            found_defs[def_name] = span

    # Build output
    output_lines = [
        "PI-JOB MIGRATION INSTRUCTION",
        "",
        f"Task file: {task_file}",
        f"Shared schema: {TASK_SCHEMA}",
        "",
    ]

    if not found_defs:
        output_lines.append("Status: already migrated — no local type declarations found; relies entirely on the shared schema.")
        print("\n".join(output_lines))
        return

    # Process each found definition
    for def_name in LOCAL_DEF_NAMES:
        if def_name not in found_defs:
            continue

        open_idx, close_idx = found_defs[def_name]
        line_range = f"{open_idx + 1}-{close_idx + 1}"  # 1-indexed for display

        if def_name == "#Status":
            block = diagnose_status(task_file, lines, raw_text, open_idx, close_idx, line_range)
        elif def_name in ("#Step", "#Decision", "#Artifact"):
            block = diagnose_struct_def(lines, open_idx, close_idx, def_name, line_range)
        elif def_name == "#Slice":
            block = diagnose_slice(lines, open_idx, close_idx, line_range)
        else:
            block = ""

        if block:
            output_lines.append("")
            output_lines.append(block)

    output_lines += [
        "",
        "Next steps:",
        "- This command only diagnoses; it does not modify the file. Make the edits above with your",
        "  normal editing tools.",
        "- After editing, run `pi-job status` and `pi-job show` on this file to confirm it still validates.",
        "- Note: a bare `cue vet` or `cue export` on the migrated task file alone will fail with",
        "  'reference not found' errors — this is expected, not breakage. Only `pi-job` subcommands",
        "  (or `cue` invoked with both files explicitly) validate the migrated file correctly.",
    ]

    print("\n".join(output_lines))


def diagnose_status(task_file: Path, lines: list[str], raw_text: str, open_idx: int, close_idx: int, line_range: str) -> str:
    """Diagnose #Status: compare local vs shared disjunction values."""
    try:
        local_values = cue_def_disjunction_values([task_file])
        shared_values = cue_def_disjunction_values([TASK_SCHEMA])
    except:
        return f"#Status (lines {line_range}):\n  Diagnosis error: could not extract disjunction values"

    extra = [v for v in local_values if v not in shared_values]

    lines_str = "\n".join([f"  Local values: {', '.join(local_values)}", f"  Shared values: {', '.join(shared_values)}"])

    if not extra:
        recommendation = f"DELETE line {open_idx + 1} — the local declaration matches the shared schema exactly. task-schema.cue is unified into every pi-job command automatically, so this local copy is redundant, not load-bearing."
        return f"#Status (lines {line_range}):\n{lines_str}\n  Recommendation: {recommendation}"

    # Check if extra values are used in instance data (status: "value" outside the #Status declaration)
    usages: dict[str, int] = {v: 0 for v in extra}
    # Grep for status: "<value>" but not in the #Status declaration line itself
    for i, line in enumerate(lines):
        # Skip the declaration line(s)
        if i >= open_idx and i <= close_idx:
            continue
        for value in extra:
            pattern = r'status:\s*"' + re.escape(value) + r'"'
            if re.search(pattern, line):
                usages[value] += 1

    extra_str = ", ".join(extra)
    used_count = sum(usages.values())

    if used_count == 0:
        recommendation = f"DELETE line {open_idx + 1} — the extra values are declared but never used in instance data."
        return f"#Status (lines {line_range}):\n{lines_str}\n  Extra (local-only, unused in this file): {extra_str}\n  Recommendation: {recommendation}"
    else:
        recommendation = f"KEEP AS-IS — the extra values are used in instance data ({used_count} usages total across the file)."
        usages_str = ", ".join(f"{v}:{usages[v]}" for v in extra)
        return f"#Status (lines {line_range}):\n{lines_str}\n  Extra (local-only, used in this file): {extra_str} ({usages_str})\n  Recommendation: {recommendation}"


def diagnose_struct_def(lines: list[str], open_idx: int, close_idx: int, def_name: str, line_range: str) -> str:
    """Diagnose #Step/#Decision/#Artifact: simple field-set-identical check."""
    try:
        local_fields = parse_def_struct_fields_from_raw(lines, open_idx, close_idx)
        shared_fields = cue_def_fields_from([TASK_SCHEMA], def_name)
    except:
        return f"{def_name} (lines {line_range}):\n  Diagnosis error: could not extract field specs"

    local_sig = {(f.name, f.optional, f.kind) for f in local_fields}
    shared_sig = {(f.name, f.optional, f.kind) for f in shared_fields}

    if local_sig == shared_sig:
        recommendation = f"DELETE line {line_range.split('-')[0]} — the local declaration is identical to the shared schema. task-schema.cue is unified into every pi-job command automatically, so this local copy is redundant, not load-bearing."
        return f"{def_name} (lines {line_range}):\n  Recommendation: {recommendation}"
    else:
        # List differences
        local_names = {f.name for f in local_fields}
        shared_names = {f.name for f in shared_fields}
        only_local = local_names - shared_names
        only_shared = shared_names - local_names
        diff_lines = []
        if only_local:
            diff_lines.append(f"    Local-only fields: {', '.join(sorted(only_local))}")
        if only_shared:
            diff_lines.append(f"    Shared-only fields: {', '.join(sorted(only_shared))}")
        diff_str = "\n".join(diff_lines) if diff_lines else "    (field-level differences exist)"
        recommendation = f"KEEP AS-IS — this definition differs from the shared schema and should not be deleted without review."
        return f"{def_name} (lines {line_range}):\n{diff_str}\n  Recommendation: {recommendation}"


def diagnose_slice(lines: list[str], open_idx: int, close_idx: int, line_range: str) -> str:
    """Diagnose #Slice: identify redundant vs delta fields."""
    try:
        local_fields = parse_def_struct_fields_from_raw(lines, open_idx, close_idx)
        shared_fields = cue_def_fields_from([TASK_SCHEMA], "#Slice")
    except:
        return f"#Slice (lines {line_range}):\n  Diagnosis error: could not extract field specs"

    local_by_name = {f.name: f for f in local_fields}
    shared_by_name = {f.name: f for f in shared_fields}

    # Identify redundant fields (same name, same kind, same optional)
    redundant = []
    delta_fields = []

    for name, local_field in local_by_name.items():
        shared_field = shared_by_name.get(name)
        if shared_field and (local_field.name, local_field.optional, local_field.kind) == (shared_field.name, shared_field.optional, shared_field.kind):
            redundant.append(name)
        else:
            delta_fields.append((name, local_field))

    redundant_str = ", ".join(sorted(redundant))

    if not delta_fields:
        recommendation = f"DELETE lines {line_range} — all fields are identical to the shared schema."
        return f"#Slice (lines {line_range}):\n  Redundant with shared (safe to drop): {redundant_str}\n  Recommendation: {recommendation}"

    # Build recommendation with delta fields and closed_items if present
    delta_names = [name for name, _ in delta_fields]
    delta_str = ", ".join(sorted(delta_names))

    # Generate the replacement code
    replacement_lines = ["    #Slice: {"]
    for name, field in delta_fields:
        if field.kind == "closed_list" and field.closed_items:
            replacement_lines.append(f"        {name}: [")
            for key, title in field.closed_items:
                replacement_lines.append(f'            #Step & {{key: "{cue_escape(key)}", title: "{cue_escape(title)}"}},')
            replacement_lines.append("        ]")
        elif field.kind == "open_list":
            replacement_lines.append(f"        {name}: [...string]")
        else:
            replacement_lines.append(f"        {name}: ...")
    replacement_lines.append("    }")

    replacement_code = "\n".join(replacement_lines)

    recommendation = f"REPLACE lines {line_range} with:\n{replacement_code}"
    return f"#Slice (lines {line_range}):\n  Redundant with shared (safe to drop): {redundant_str}\n  Local-only delta (must keep): {delta_str}\n  Recommendation: {recommendation}"


def main() -> None:
    profiles = sorted(valid_profiles())
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--task", type=Path, required=True, help="CUE task file to orchestrate")
    sub = ap.add_subparsers(dest="cmd", required=True)

    status = sub.add_parser("status", help="show task status, saved cursor, and next cursor")
    status.set_defaults(fn=cmd_status)

    init = sub.add_parser("init", help="initialize task orchestration with an explicit profile")
    init.add_argument("--profile", required=True, choices=profiles)
    init.add_argument("--dry-run", action="store_true")
    init.set_defaults(fn=cmd_init)

    nxt = sub.add_parser("next", help="print the next unfinished slice/step")
    nxt.add_argument("--all", action="store_true", help="list all dependency-satisfied slices")
    nxt.set_defaults(fn=cmd_next)

    adv = sub.add_parser("advance", help="set cursor to the next unfinished step or an explicit cursor")
    adv.add_argument("--phase", help="explicit phase to set; defaults to computed next")
    adv.add_argument("--slice", help="explicit slice key")
    adv.add_argument("--step", help="explicit step key")
    adv.add_argument("--dry-run", action="store_true")
    adv.add_argument("--force", action="store_true", help="advance past an unfinished current step")
    adv.add_argument("--reason", help="required with --force; recorded skip reason")
    adv.set_defaults(fn=cmd_advance)

    plan = sub.add_parser("plan", help="print profile phase plan from profile-contract.cue")
    plan.set_defaults(fn=cmd_plan)

    tb = sub.add_parser("toolbelt", help="list toolbelt aids for the profile, or add one")
    tb.add_argument("action", nargs="?", choices=["add"], help="'add' to register an aid")
    tb.add_argument("key", nargs="?", help="aid key when using add")
    tb.add_argument("--path", help="artifact path to record")
    tb.add_argument("--status", default="planned", help="artifact status (default planned)")
    tb.add_argument("--note", default="", help="artifact note")
    tb.set_defaults(fn=cmd_toolbelt)

    show = sub.add_parser("show", help="render the task as a cursor-focused slice/step tree")
    show.add_argument("--all", action="store_true", help="expand every slice's steps")
    show.add_argument("--status", help="comma-separated slice statuses to include")
    show.set_defaults(fn=cmd_show)

    instruction = sub.add_parser("instruction", help="emit deterministic instructions for the current or next cursor")
    instruction.add_argument("--current", action="store_true", help="use saved cursor instead of computed next")
    instruction.set_defaults(fn=cmd_instruction)

    scaffold = sub.add_parser(
        "scaffold",
        help="create a task file from the generic example shape when one does not exist yet",
    )
    scaffold.add_argument("--title", default="Example bounded change", help="task.title for the scaffold")
    scaffold.add_argument("--force", action="store_true", help="overwrite an existing task file")
    scaffold.add_argument("--dry-run", action="store_true", help="print the scaffold without writing")
    scaffold.set_defaults(fn=cmd_scaffold)

    add_slice = sub.add_parser("add-slice", help="append a new #Slice to plan.slices, deriving required fields/final_steps shape from this file's own #Slice schema (cue def)")
    add_slice.add_argument("--key", required=True)
    add_slice.add_argument("--title", required=True)
    add_slice.add_argument("--goal", required=True)
    add_slice.add_argument("--repos", help="comma-separated; required if this file's #Slice schema declares repos as non-optional")
    add_slice.add_argument("--depends-on", help="comma-separated slice keys this slice depends on")
    add_slice.add_argument("--after", help="insert after this existing slice key; default: end of plan.slices")
    add_slice.add_argument("--dry-run", action="store_true")
    add_slice.set_defaults(fn=cmd_add_slice)

    add_step = sub.add_parser("add-step", help="append a new #Step to a slice's steps (or final_steps with --final)")
    add_step.add_argument("--slice", required=True)
    add_step.add_argument("--key", required=True)
    add_step.add_argument("--title", required=True)
    add_step.add_argument("--note", default="")
    add_step.add_argument("--final", action="store_true")
    add_step.add_argument("--after", help="insert after this existing step key; default: end of the target array")
    add_step.add_argument("--dry-run", action="store_true")
    add_step.set_defaults(fn=cmd_add_step)

    set_worktree = sub.add_parser("set-worktree", help="record or update the filesystem worktree path for a slice's repo work")
    set_worktree.add_argument("--slice", required=True)
    set_worktree.add_argument("--repo", required=True)
    set_worktree.add_argument("--path", required=True)
    set_worktree.add_argument("--dry-run", action="store_true")
    set_worktree.set_defaults(fn=cmd_set_worktree)

    add_pr = sub.add_parser("add-pr", help="record a PR for a slice's repo work, upserting by URL if it already exists")
    add_pr.add_argument("--slice", required=True)
    add_pr.add_argument("--repo", required=True)
    add_pr.add_argument("--url", required=True)
    add_pr.add_argument("--status", required=True, choices=["open", "merged", "closed"])
    add_pr.add_argument("--note", default="")
    add_pr.add_argument("--dry-run", action="store_true")
    add_pr.set_defaults(fn=cmd_add_pr)

    migrate_task = sub.add_parser(
        "migrate-task",
        help="diagnose a task file's legacy local schema declarations against the shared task-schema.cue and print migration guidance",
        description="Diagnose a task file for legacy local type declarations (#Status, #Step, #Decision, #Artifact, #Slice) that became redundant after task-schema.cue was added. Compares each local declaration against the shared schema and recommends whether to delete or refactor. This command only diagnoses and never modifies the file — it explains what is safe to delete and what must be kept based on actual content analysis.",
    )
    migrate_task.set_defaults(fn=cmd_migrate_task)

    args = ap.parse_args()
    args.fn(args)


if __name__ == "__main__":
    main()
